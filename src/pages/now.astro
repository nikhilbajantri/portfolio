---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Now">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[68ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-12 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Now
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        This is a live page documenting my current priorities, active learning paths, and what I'm building right now. Inspired by Derek Sivers.
      </p>
    </header>

    <!-- Now Categories -->
    <div class="flex flex-col gap-8 text-[#FAFAFA] text-base leading-[1.7] tracking-tight font-normal">
      
      <!-- Building -->
      <section class="flex flex-col gap-2">
        <h2 class="text-xs text-[#71717A] uppercase tracking-wider font-semibold">Building</h2>
        <p class="text-[#A1A1AA] text-sm">
          <strong class="text-[#FAFAFA] font-medium">DailyDine</strong> — An independent, local-first reservation platform for restaurants. Currently optimizing Postgres transaction locks to handle peak booking concurrency.
        </p>
      </section>

      <!-- Reading -->
      <section class="flex flex-col gap-2">
        <h2 class="text-xs text-[#71717A] uppercase tracking-wider font-semibold">Reading</h2>
        <p class="text-[#A1A1AA] text-sm">
          <strong class="text-[#FAFAFA] font-medium">Designing Data-Intensive Applications</strong> by Martin Kleppmann. Focusing on database replication limits, storage engines, and consensus algorithms.
        </p>
      </section>

      <!-- Learning -->
      <section class="flex flex-col gap-2">
        <h2 class="text-xs text-[#71717A] uppercase tracking-wider font-semibold">Learning</h2>
        <p class="text-[#A1A1AA] text-sm">
          <strong class="text-[#FAFAFA] font-medium">Linux Networking</strong>. Studying iptables configuration patterns, packet routing layers, and local socket descriptors.
        </p>
      </section>

      <!-- Thinking About -->
      <section class="flex flex-col gap-2">
        <h2 class="text-xs text-[#71717A] uppercase tracking-wider font-semibold">Thinking About</h2>
        <p class="text-[#A1A1AA] text-sm">
          <strong class="text-[#FAFAFA] font-medium">AI Developer Tools</strong>. How large language models can be combined with local sandboxed compilation to speed up manual refactoring loops safely.
        </p>
      </section>

      <!-- Updated timestamp -->
      <footer class="flex flex-col gap-1 border-t border-[rgba(255,255,255,0.06)] pt-6 mt-4 text-xs font-mono text-[#71717A]">
        <span>Last Updated: July 2026</span>
        <span>Location: Bengaluru, India</span>
      </footer>

    </div>

  </main>

  <Footer />
</Layout>
