---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Now">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[72ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Now
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        What I'm doing today: a live update of active priorities, domains of study, and open questions.
      </p>
    </header>

    <!-- Priorities & Domain Exploration -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-12">
      
      <!-- Priorities -->
      <section class="flex flex-col gap-4">
        <h2 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
          Priorities
        </h2>
        <ul class="flex flex-col gap-3 text-sm text-[#A1A1AA]">
          <li class="flex items-start gap-2">
            <span class="text-[#2563EB] font-bold">•</span>
            Building thoughtful software
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#2563EB] font-bold">•</span>
            Developing stronger engineering fundamentals
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#2563EB] font-bold">•</span>
            Learning cybersecurity
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#2563EB] font-bold">•</span>
            Writing consistently
          </li>
        </ul>
      </section>

      <!-- Currently Exploring -->
      <section class="flex flex-col gap-4">
        <h2 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
          Exploring
        </h2>
        <ul class="flex flex-col gap-3 text-sm text-[#A1A1AA]">
          <li class="flex items-start gap-2">
            <span class="text-[#2563EB] font-bold">•</span>
            Cybersecurity and computer systems
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#2563EB] font-bold">•</span>
            Distributed systems architecture
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#2563EB] font-bold">•</span>
            Linux kernel networking and compilers
          </li>
        </ul>
      </section>

    </div>

    <!-- Currently (Status Indicators) -->
    <section class="flex flex-col gap-6 border-t border-[rgba(255,255,255,0.08)] pt-12">
      <h2 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        Status
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm text-[#A1A1AA]">
        <div>
          <span class="text-[#71717A] block text-xs">Listening To</span>
          Ambient soundscapes
        </div>
        <div>
          <span class="text-[#71717A] block text-xs">Reading</span>
          "The Pragmatic Programmer"
        </div>
        <div>
          <span class="text-[#71717A] block text-xs">Learning</span>
          Linux kernel fundamentals
        </div>
        <div>
          <span class="text-[#71717A] block text-xs">Building</span>
          DailyDine core reservation engine
        </div>
        <div>
          <span class="text-[#71717A] block text-xs">Thinking About</span>
          Build systems that endure
        </div>
      </div>
    </section>

    <!-- Open Questions -->
    <section class="flex flex-col gap-4 border-t border-[rgba(255,255,255,0.08)] pt-12">
      <h2 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        Open Questions
      </h2>
      <ul class="flex flex-col gap-3 text-sm text-[#A1A1AA]">
        <li class="flex items-start gap-2">
          <span class="text-[#2563EB] font-bold">•</span>
          How should AI change software engineering?
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[#2563EB] font-bold">•</span>
          What makes software feel trustworthy?
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[#2563EB] font-bold">•</span>
          Can security become invisible?
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[#2563EB] font-bold">•</span>
          How do great engineering cultures emerge?
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[#2563EB] font-bold">•</span>
          What makes products endure?
        </li>
      </ul>
    </section>

  </main>

  <Footer />
</Layout>
