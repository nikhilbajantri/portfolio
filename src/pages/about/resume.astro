---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";

const experience = [
  {
    period: "2024 - Present",
    role: "Software Engineer",
    company: "DailyDine",
    details: "Developing scheduling algorithms and backend API systems for dining reservation software. Optimizing database query paths to minimize latency."
  }
];

const projects = [
  {
    name: "DailyDine Reservation Engine",
    role: "Lead Engineer",
    details: "Built an event-driven lock queue preventing concurrency double bookings. Implemented transactional scheduling models in PostgreSQL."
  },
  {
    name: "HisabProx Invoice Tool",
    role: "Creator",
    details: "Designed a local-first browser-based invoice compiler. Secured complete client privacy without relying on backend database services."
  }
];

const education = [
  {
    period: "2024 - 2028",
    degree: "Bachelor of Engineering in Artificial Intelligence & Data Science",
    institution: "Srinivas Institute of Technology"
  }
];

const skills = [
  "Go",
  "TypeScript",
  "Node.js",
  "React",
  "PostgreSQL",
  "Linux Systems",
  "Network Basics"
];
---

<Layout title="Resume">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[72ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-12 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col sm:flex-row justify-between sm:items-baseline gap-4">
      <div class="flex flex-col gap-2">
        <h1 class="text-4xl sm:text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
          Résumé
        </h1>
        <p class="text-sm text-[#A1A1AA]">
          Nikhil Bajantri · Software Engineer
        </p>
      </div>
      <div>
        <a 
          href="/resume.pdf" 
          download 
          class="inline-block px-4 py-2 bg-[#111113] hover:bg-[#18181B] text-xs font-medium text-[#FAFAFA] border border-[rgba(255,255,255,0.08)] rounded-[12px] transition-colors duration-180"
        >
          Download PDF
        </a>
      </div>
    </header>

    <!-- Summary -->
    <section class="flex flex-col gap-3">
      <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider">Summary</h2>
      <p class="text-sm text-[#A1A1AA] leading-relaxed">
        Software engineer focusing on backend systems development, security practices, and systems optimization.
        Experienced in building concurrency engines, client-side tools, and relational database schemas.
        Optimizes systems to achieve predictability, clean maintainability, and zero runtime waste.
      </p>
    </section>

    <!-- Experience -->
    <section class="flex flex-col gap-6">
      <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider">Experience</h2>
      <div class="flex flex-col gap-6">
        {experience.map((job) => (
          <div class="flex flex-col gap-1.5">
            <div class="flex justify-between items-baseline gap-4">
              <h3 class="text-sm font-medium text-[#FAFAFA]">{job.role}</h3>
              <span class="text-xs text-[#71717A] font-mono">{job.period}</span>
            </div>
            <p class="text-xs text-[#71717A] font-medium">{job.company}</p>
            <p class="text-sm text-[#A1A1AA] leading-relaxed mt-1">{job.details}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Selected Projects -->
    <section class="flex flex-col gap-6">
      <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider">Selected Projects</h2>
      <div class="flex flex-col gap-6">
        {projects.map((proj) => (
          <div class="flex flex-col gap-1">
            <div class="flex justify-between items-baseline gap-4">
              <h3 class="text-sm font-medium text-[#FAFAFA]">{proj.name}</h3>
              <span class="text-xs text-[#71717A] font-mono">{proj.role}</span>
            </div>
            <p class="text-sm text-[#A1A1AA] leading-relaxed mt-1">{proj.details}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section class="flex flex-col gap-6">
      <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider">Education</h2>
      <div class="flex flex-col gap-6">
        {education.map((edu) => (
          <div class="flex flex-col gap-1">
            <div class="flex justify-between items-baseline gap-4">
              <h3 class="text-sm font-medium text-[#FAFAFA]">{edu.degree}</h3>
              <span class="text-xs text-[#71717A] font-mono">{edu.period}</span>
            </div>
            <p class="text-xs text-[#71717A]">{edu.institution}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Skills (No ratings) -->
    <section class="flex flex-col gap-3">
      <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider">Skills</h2>
      <div class="flex flex-wrap gap-2">
        {skills.map((skill) => (
          <span class="px-3 py-1 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[999px] text-xs text-[#A1A1AA]">
            {skill}
          </span>
        ))}
      </div>
    </section>

  </main>

  <Footer />
</Layout>
