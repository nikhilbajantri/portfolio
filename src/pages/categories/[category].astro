---
import CollectionLayout from "../../layouts/CollectionLayout.astro";
import { getArticles } from "../../lib/content";

export async function getStaticPaths() {
  const articles = await getArticles();
  const categories = new Set(articles.map(a => a.data.category.toLowerCase()));
  return Array.from(categories).map(category => ({
    params: { category },
    props: { category }
  }));
}

const { category } = Astro.props;
const articles = (await getArticles()).filter(a => a.data.category.toLowerCase() === category);
---

<CollectionLayout title={`Category: ${category.charAt(0).toUpperCase() + category.slice(1)}`}>
  <main id="main-content" class="flex-1 max-w-[68ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-12 font-sans">
    
    <header class="flex flex-col gap-2">
      <span class="text-xs font-mono text-[#71717A] uppercase tracking-wider">Category</span>
      <h1 class="text-4xl font-display font-medium text-[#FAFAFA] tracking-tight capitalize">{category}</h1>
    </header>

    <div class="flex flex-col gap-6">
      {articles.map(a => (
        <a href={`/writing/${a.slug}`} class="group flex flex-col gap-1 border-b border-[rgba(255,255,255,0.04)] pb-4">
          <span class="text-sm font-medium text-white group-hover:text-[#2563EB] transition-colors">{a.data.title}</span>
          <span class="text-xs text-[#A1A1AA] line-clamp-1 leading-normal">{a.data.description}</span>
          <span class="text-[10px] text-[#71717A] font-mono mt-1">{a.data.published.toLocaleDateString("en-US", { year: "numeric", month: "long" })}</span>
        </a>
      ))}
    </div>

  </main>
</CollectionLayout>
