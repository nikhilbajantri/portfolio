---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { getKnowledgeItems } from "../lib/content";

const items = await getKnowledgeItems();

// Group knowledge items by category
const categories = Array.from(new Set(items.map(item => item.data.category)));
---

<Layout title="Knowledge">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[960px] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6 max-w-[68ch]">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Knowledge Base
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        A structured directory of specifications, references, and core manuals I study.
      </p>
    </header>

    <!-- Knowledge Index Categories -->
    <div class="flex flex-col gap-16">
      {categories.map((cat) => {
        const catItems = items.filter(item => item.data.category === cat);
        return (
          <section class="flex flex-col gap-8">
            <h2 class="text-xs font-mono text-[#71717A] uppercase tracking-wider border-b border-white/5 pb-2 font-semibold">
              {cat}
            </h2>
            <div class="flex flex-col gap-10">
              {catItems.map(item => (
                <div class="flex flex-col gap-3 max-w-[680px]">
                  <div class="flex justify-between items-baseline gap-2">
                    <h3 class="text-lg font-medium text-[#FAFAFA]">
                      <a href={`/knowledge/${item.id}`} class="hover:text-[#2563EB] transition-colors">{item.data.title}</a>
                    </h3>
                    <span class="text-xs text-[#71717A] font-mono">{item.data.difficulty} · {item.data.status}</span>
                  </div>
                  <p class="text-sm text-[#A1A1AA] leading-relaxed">
                    <strong>Why it matters:</strong> {item.data.why}
                  </p>
                  <p class="text-xs text-[#71717A] leading-relaxed">
                    <strong>Best for:</strong> {item.data.bestFor}
                  </p>
                </div>
              ))}
            </div>
          </section>
        );
      })}
    </div>

  </main>

  <Footer />
</Layout>
