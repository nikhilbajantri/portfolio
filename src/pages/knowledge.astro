---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

const topics = [
  {
    title: "Systems",
    resources: [
      {
        name: "The Linux Programming Interface",
        type: "Book",
        why: "The definitive guide to Linux system calls, process boundaries, and file descriptor controls. It is my primary reference for understanding kernel abstractions.",
        bestFor: "Systems programmers needing an authoritative manual for Linux system interfaces.",
        related: [
          { name: "Learning Linux From Scratch", url: "/writing/learning-linux-from-scratch" },
          { name: "Socket Descriptors Note", url: "/notes" }
        ]
      }
    ]
  },
  {
    title: "Security",
    resources: [
      {
        name: "Keycloak Server Administration",
        type: "Documentation",
        why: "Central reference for deploying self-hosted OpenID Connect identity provider configurations and role-based access rules.",
        bestFor: "Security engineers implementing robust OIDC flows and credentials boundaries.",
        related: [
          { name: "CodeBud Case Study", url: "/work/codebud" },
          { name: "Analyzing JWT Authentication", url: "/writing/analyzing-jwt-authentication" }
        ]
      }
    ]
  },
  {
    title: "Backend",
    resources: [
      {
        name: "Go Standard Library Specification",
        type: "Reference Documentation",
        why: "A masterclass in API design, self-contained concurrency primitives, and minimal dependency boundaries.",
        bestFor: "Backend developers seeking to write lightweight, high-throughput network services.",
        related: [
          { name: "DailyDine Case Study", url: "/work/dailydine" }
        ]
      }
    ]
  },
  {
    title: "Networking",
    resources: [
      {
        name: "TCP/IP Illustrated, Vol. 1",
        type: "Book",
        why: "Deeply documents socket buffers, congestion control algorithms, sliding windows, and protocol routing boundaries.",
        bestFor: "Network security engineers auditing low-level packet transmission states.",
        related: [
          { name: "Linux Network Security", url: "/writing/linux-network-security" },
          { name: "TCP Handshake Explorer", url: "/lab/tcp-handshake" }
        ]
      }
    ]
  },
  {
    title: "Distributed Systems",
    resources: [
      {
        name: "Designing Data-Intensive Applications",
        type: "Book",
        why: "The absolute standard for understanding consensus boundaries, replication logs, transaction isolates, and partition compromises.",
        bestFor: "Backend architects managing data consistency and state replication across network gaps.",
        related: [
          { name: "PostgreSQL MVCC Note", url: "/notes" },
          { name: "Why Small Systems Win", url: "/writing/why-small-systems-win" }
        ]
      }
    ]
  },
  {
    title: "AI",
    resources: [
      {
        name: "Attention Is All You Need",
        type: "Paper",
        why: "The foundational research paper introducing transformer layers, self-attention mechanics, and matrix weight transformations.",
        bestFor: "Developers seeking to understand the mathematical mechanics of modern models.",
        related: [
          { name: "Self-Attention Note", url: "/notes" }
        ]
      }
    ]
  }
];
---

<Layout title="Knowledge">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[960px] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6 max-w-[68ch]">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Knowledge
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        A long-term knowledge base of books, papers, documentation, and references that have shaped my thinking, paired with my related case studies and notes.
      </p>
    </header>

    <!-- Topics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {topics.map((t) => (
        <section class="flex flex-col gap-6">
          <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.06)] pb-2 font-mono">
            {t.title}
          </h2>
          
          <div class="flex flex-col gap-8">
            {t.resources.map((res) => (
              <div class="flex flex-col gap-3">
                <div class="flex justify-between items-baseline gap-2">
                  <h3 class="text-base font-medium text-[#FAFAFA]">{res.name}</h3>
                  <span class="text-[10px] font-mono text-[#71717A]">{res.type}</span>
                </div>
                
                <p class="text-sm text-[#A1A1AA] leading-relaxed">
                  <span class="text-xs text-[#71717A] block font-mono uppercase tracking-wider mb-1">Why it matters</span>
                  {res.why}
                </p>
                
                <div class="text-xs text-[#71717A] leading-relaxed">
                  <span class="text-[10px] block font-mono uppercase tracking-wider mb-0.5">Best For</span>
                  {res.bestFor}
                </div>

                <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs font-mono mt-1 pt-2 border-t border-[rgba(255,255,255,0.04)]">
                  <span class="text-[#71717A]">Related:</span>
                  {res.related.map((rel, index) => (
                    <>
                      <a href={rel.url} class="text-[#2563EB] hover:underline">{rel.name}</a>
                      {index < res.related.length - 1 && <span class="text-[#71717A]">•</span>}
                    </>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

  </main>

  <Footer />
</Layout>
