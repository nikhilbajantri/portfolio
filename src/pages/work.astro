---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { getProjects } from "../lib/content";

const projects = await getProjects();

// Group projects by category
const categories = ["Selected Work", "Archive"];
const grouped = categories.reduce((acc, cat) => {
  acc[cat] = projects.filter(p => p.data.category === cat);
  return acc;
}, {} as Record<string, typeof projects>);
---

<Layout title="Work">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[960px] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6 max-w-[68ch]">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Work
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        Real-world implementations, software platforms, and systems design case studies I've led or built.
      </p>
    </header>

    <!-- Projects Catalog -->
    <div class="flex flex-col gap-16">
      {categories.map((cat) => {
        const list = grouped[cat] || [];
        if (list.length === 0) return null;
        return (
          <section class="flex flex-col gap-8">
            <h2 class="text-xs font-mono text-[#71717A] uppercase tracking-wider border-b border-white/5 pb-2 font-semibold">
              {cat}
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {list.map(project => (
                <a 
                  href={project.data.caseStudy || `/work/${project.slug}`} 
                  class="p-6 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-3 hover:border-[#2563EB]/40 transition-colors"
                >
                  <div class="flex justify-between items-baseline gap-2">
                    <h3 class="text-sm font-medium text-[#FAFAFA]">{project.data.title}</h3>
                    <span class="text-xs text-[#71717A] font-mono">{project.data.year}</span>
                  </div>
                  <p class="text-xs text-[#A1A1AA] leading-relaxed line-clamp-2">
                    {project.data.description}
                  </p>
                  <div class="text-[10px] font-mono text-[#71717A] mt-auto">
                    Languages: {project.data.languages?.join(", ") || "None"}
                  </div>
                </a>
              ))}
            </div>
          </section>
        );
      })}
    </div>

  </main>

  <Footer />
</Layout>
