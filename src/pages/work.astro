---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

const projects = [
  {
    title: "DailyDine",
    subtitle: "Dining coordination platform",
    overview: "DailyDine coordinates table reservations for local restaurants, focusing on scheduling reliability.",
    challenge: "Balancing table inventory with customer convenience under high reservation concurrency.",
    approach: "Designed an event-driven lock system to prevent overbooking during peak dining hours.",
    architecture: "React frontend communicating with a Go backend and a PostgreSQL database.",
    tradeoffs: "Chose server-side polling instead of WebSockets to reduce state management complexity on the server.",
    outcome: "Coordinated reservations across three venues, reducing customer wait times.",
    lessons: "Simple database transactions are easier to maintain than distributed reservation state machines.",
    tech: ["Go", "React", "PostgreSQL", "Tailwind CSS"],
    slug: "/work/dailydine"
  },
  {
    title: "HisabProx",
    subtitle: "Local invoice utility",
    overview: "HisabProx helps freelance developers generate and manage client invoices without external database storage.",
    challenge: "Ensuring developer data privacy without hosting expensive cloud database infrastructure.",
    approach: "Built a client-side storage utility that runs completely locally in the browser.",
    architecture: "Static TypeScript app utilizing local storage and client-side PDF compilation.",
    tradeoffs: "Traded multi-device synchronization for complete client privacy and zero server maintenance costs.",
    outcome: "Active local utility used to draft and compile PDF invoices daily.",
    lessons: "The most secure and cost-effective system is the one that avoids storing data on a remote server.",
    tech: ["TypeScript", "React", "Local Storage", "PDFKit"],
    slug: "/work/hisabprox"
  }
];
---

<Layout title="Work">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[960px] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6 max-w-[72ch]">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Work
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        Thoughtful systems and utilities built with precision.
        I value simple design patterns, complete data ownership, and minimal runtime overhead.
      </p>
    </header>

    <!-- Case Studies List -->
    <div class="flex flex-col gap-16">
      {projects.map((project) => (
        <article class="p-8 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-6">
          <div class="flex flex-col gap-1">
            <h2 class="text-2xl font-display font-medium text-[#FAFAFA]">{project.title}</h2>
            <p class="text-xs text-[#71717A] font-mono">{project.subtitle}</p>
          </div>

          <p class="text-base text-[#A1A1AA] leading-relaxed">
            {project.overview}
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm text-[#A1A1AA] border-t border-[rgba(255,255,255,0.04)] pt-6">
            <div>
              <span class="font-medium text-[#FAFAFA] block mb-2 text-xs uppercase tracking-wider">The Challenge</span>
              {project.challenge}
            </div>
            <div>
              <span class="font-medium text-[#FAFAFA] block mb-2 text-xs uppercase tracking-wider">The Architecture</span>
              {project.architecture}
            </div>
          </div>

          <div class="flex justify-between items-center mt-6 border-t border-[rgba(255,255,255,0.04)] pt-6">
            <span class="text-xs font-mono text-[#71717A]">
              {project.tech.join(" · ")}
            </span>
            <a href={project.slug} class="text-sm text-[#2563EB] hover:underline font-medium">
              View Case Study
            </a>
          </div>
        </article>
      ))}
    </div>

  </main>

  <Footer />
</Layout>
