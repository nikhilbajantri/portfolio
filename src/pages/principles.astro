---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

const principles = [
  {
    topic: "Learning",
    statement: "Study foundational systems instead of chasing framework trends. Understanding core mechanics compounds, while APIs expire."
  },
  {
    topic: "Building",
    statement: "Keep systems simple and code readable. Every dependency added is a potential point of failure. Write code that survives deletions."
  },
  {
    topic: "Writing",
    statement: "Write to clarify complex concepts. Use simple words and stories rather than marketing jargon. Aim to make the reader feel intelligent."
  },
  {
    topic: "Reading",
    statement: "Read books to shift your perspective and build technical judgment. Re-read quality resources rather than rushing to finish lists."
  },
  {
    topic: "Engineering",
    statement: "Prioritize reliability over clever solutions. Choose stable, boring technologies that scale predictably under load."
  },
  {
    topic: "Decision Making",
    statement: "Evaluate engineering choices by their long-term trade-offs. Play the long game rather than chasing quick accolades."
  },
  {
    topic: "Quality",
    statement: "Focus attention on invisible details. Code organization, semantic HTML, and accessibility are the foundations of true craft."
  },
  {
    topic: "Curiosity",
    statement: "Maintain a lifelong student mindset. Accept mistakes publicly, correct them, and learn in public with humility."
  }
];
---

<Layout title="Principles">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[72ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Principles
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        The core principles that shape my engineering decisions, learning workflow, and long-term values.
      </p>
    </header>

    <!-- Principles list -->
    <div class="flex flex-col gap-10">
      {principles.map((principle) => (
        <section class="flex flex-col gap-3">
          <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-1.5">
            {principle.topic}
          </h2>
          <p class="text-sm text-[#A1A1AA] leading-relaxed">
            {principle.statement}
          </p>
        </section>
      ))}
    </div>

  </main>

  <Footer />
</Layout>
