---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

const principles = [
  {
    title: "Build Slowly",
    description: "Take time to study the systems you use. Rushing to ship adds hidden technical debt. Understanding core mechanics compounds, while APIs expire."
  },
  {
    title: "Learn Publicly",
    description: "Document lessons and correct mistakes in the open. Sharing the progress of understanding builds trust. Intellectual honesty is a permanent asset."
  },
  {
    title: "Prefer Clarity",
    description: "Write simple, readable code that is easy to maintain. Clever tricks introduce points of failure. Choose straightforward designs that survive deletion tests."
  },
  {
    title: "Stay Curious",
    description: "Explore domains out of interest rather than utility. Read specifications, manuals, and RFC sheets. Great engineering requires builders' humility and focus."
  },
  {
    title: "Think Long-Term",
    description: "Prioritize reliability over hype. Choose boring, stable technologies that scale predictably. Build tools that still make sense ten years from now."
  },
  {
    title: "Leave Things Better",
    description: "Improve code blocks and documentation whenever you edit them. Small optimizations compound. Leave every system slightly clearer than you found it."
  }
];
---

<Layout title="Principles">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[72ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Principles
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed max-w-[65ch]">
        The core philosophies that guide my technical decisions, learning habits, and long-term work.
      </p>
    </header>

    <!-- Principles list -->
    <div class="flex flex-col gap-10">
      {principles.map((p) => (
        <section class="flex flex-col gap-3">
          <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.06)] pb-1.5">
            {p.title}
          </h2>
          <p class="text-sm text-[#A1A1AA] leading-relaxed max-w-[65ch]">
            {p.description}
          </p>
        </section>
      ))}
    </div>

  </main>

  <Footer />
</Layout>
