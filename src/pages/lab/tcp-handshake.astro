---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="TCP Handshake Explorer - Lab">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[68ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-12 font-sans">
    
    <!-- Top Bar Navigation -->
    <div class="text-xs text-[#71717A] font-mono border-b border-[rgba(255,255,255,0.06)] pb-4">
      <a href="/lab" class="hover:text-[#FAFAFA] transition-colors">← Back to Lab</a>
    </div>

    <!-- Header Section -->
    <header class="flex flex-col gap-4">
      <div class="flex gap-2 text-xs text-[#71717A] font-mono uppercase tracking-wider">
        <span>Lab Experiment 02</span>
      </div>
      <h1 class="text-4xl font-display font-medium text-[#FAFAFA] tracking-tight leading-tight">
        TCP Handshake Explorer
      </h1>
      <p class="text-base text-[#A1A1AA] leading-relaxed">
        An interactive simulator visualizing connection establishment, data transfer, and socket termination states.
      </p>
    </header>

    <!-- Content Sections following standard template -->
    <div class="flex flex-col gap-12 text-[#FAFAFA] text-sm leading-[1.7] tracking-tight font-normal">
      
      <!-- 1. Problem -->
      <section class="flex flex-col gap-3">
        <h2 class="text-xs text-[#71717A] uppercase tracking-wider font-semibold font-mono">01. The Problem</h2>
        <p class="text-[#A1A1AA]">
          Unlike stateless protocols like UDP, TCP guarantees delivery order and packet checks by maintaining active connection states. Understanding how sockets transition from handshake flags to TIME_WAIT and closure is critical for troubleshooting server port exhaustion and connection resets.
        </p>
      </section>

      <!-- 2. Visual Explanation -->
      <section class="flex flex-col gap-3">
        <h2 class="text-xs text-[#71717A] uppercase tracking-wider font-semibold font-mono">02. Visual Explanation</h2>
        <p class="text-[#A1A1AA]">
          A complete TCP session involves sequence numbers (`Seq`) and acknowledgment numbers (`Ack`) to negotiate states. Sockets transit systematically:
        </p>
        <div class="bg-[#111113] border border-[rgba(255,255,255,0.04)] p-4 rounded-lg font-mono text-xs flex flex-col gap-1.5 text-[#A1A1AA]">
          <div>1. <span class="text-white">SYN</span>: Client sends initial random sequence number X.</div>
          <div>2. <span class="text-white">SYN-ACK</span>: Server acknowledges X, sends its own sequence Y.</div>
          <div>3. <span class="text-white">ACK</span>: Client acknowledges Y. Connection becomes <span class="text-green-400">ESTABLISHED</span>.</div>
          <div>4. <span class="text-white">FIN</span>: Socket closure sequence begins.</div>
          <div>5. <span class="text-white">TIME_WAIT</span>: Client waits to ensure server received the final ACK before socket reuse.</div>
        </div>
      </section>

      <!-- 3. Interactive Demo -->
      <section class="flex flex-col gap-4 border border-[rgba(255,255,255,0.06)] p-6 rounded-xl bg-[#111113]">
        <h2 class="text-xs text-white uppercase tracking-wider font-semibold font-mono">03. Interactive Demo</h2>
        
        <!-- Simulator Window -->
        <div class="flex flex-col gap-4">
          
          <!-- Packet Visualization Graph -->
          <div class="bg-[#18181B] border border-[#27272A] rounded-lg p-4 font-mono text-xs flex flex-col gap-4">
            
            <div class="flex justify-between font-sans font-medium text-white px-2">
              <span>Client (192.168.1.5)</span>
              <span>Server (203.0.113.8)</span>
            </div>

            <!-- Flow Visual -->
            <div id="flow-visual" class="h-28 flex flex-col justify-center items-center border-y border-[rgba(255,255,255,0.04)] py-4 relative">
              <!-- Flow line arrow representation -->
              <div id="packet-arrow" class="w-full text-center text-[#2563EB] font-bold text-xs transition-all duration-300">
                [ Waiting for Handshake ]
              </div>
              <div id="packet-details" class="text-[10px] text-[#71717A] mt-2 font-mono">
                Click Next to initiate SYN
              </div>
            </div>

            <!-- State Readout -->
            <div class="grid grid-cols-2 gap-4 text-[11px] text-[#A1A1AA]">
              <div>Client Socket: <span id="client-state" class="text-red-400">CLOSED</span></div>
              <div>Server Socket: <span id="server-state" class="text-red-400">LISTEN</span></div>
            </div>

          </div>

          <!-- Console log output -->
          <div class="flex flex-col gap-1.5">
            <span class="text-xs font-mono text-[#71717A]">Terminal Output Log</span>
            <pre id="terminal-log" class="bg-[#18181B] border border-[#27272A] p-3 rounded-lg text-xs font-mono text-green-400 h-28 overflow-y-auto leading-relaxed">
[System] Socket listener running on port 80...
[System] Click 'Step Handshake' to begin.
            </pre>
          </div>

          <!-- Controls -->
          <div class="flex gap-4 justify-between">
            <button id="reset-btn" class="px-3 py-1.5 bg-[#27272A] text-white rounded text-xs hover:bg-[#3f3f46] font-mono transition-colors">Reset</button>
            <button id="step-btn" class="px-4 py-1.5 bg-[#2563EB] text-white rounded text-xs hover:bg-[#1d4ed8] font-mono transition-colors">Step Handshake →</button>
          </div>

        </div>
      </section>

      <!-- 4. What's Happening -->
      <section class="flex flex-col gap-3">
        <h2 class="text-xs text-[#71717A] uppercase tracking-wider font-semibold font-mono">04. What's Happening</h2>
        <p class="text-[#A1A1AA]">
          During the steps, both hosts update internal buffer maps. If the client closes the connection, it sends a `FIN` flag. The server responds with `ACK` and its own `FIN`. The client acknowledges this final packet, but the client socket does not close immediately; it enters `TIME_WAIT` for two Maximum Segment Lifetimes (2MSL) to prevent stale packets from corrupting subsequent sockets.
        </p>
      </section>

      <!-- 5. Common Mistakes -->
      <section class="flex flex-col gap-3">
        <h2 class="text-xs text-[#71717A] uppercase tracking-wider font-semibold font-mono">05. Common Mistakes</h2>
        <ul class="list-disc pl-5 text-[#A1A1AA] flex flex-col gap-1.5">
          <li>Ignoring `TIME_WAIT` accumulations. High concurrency apps can deplete available source ports, triggering connection errors.</li>
          <li>Setting TCP keep-alive timers too high, leaving dead connection slots open in memory.</li>
          <li>Forgetting that TCP handles byte boundaries, not application message bounds, which requires framing strategies.</li>
        </ul>
      </section>

      <!-- 6. Real-world Example -->
      <section class="flex flex-col gap-3">
        <h2 class="text-xs text-[#71717A] uppercase tracking-wider font-semibold font-mono">06. Real-world Example</h2>
        <p class="text-[#A1A1AA]">
          In high-volume platforms, we use load balancer proxies to terminate TCP sessions at the edge. The proxy handles the handshake and passes traffic back over persistent connections, protecting application processes from connection negotiation overhead.
        </p>
      </section>

      <!-- 7. Further Reading -->
      <section class="flex flex-col gap-3 border-t border-[rgba(255,255,255,0.06)] pt-6">
        <h2 class="text-xs text-[#71717A] uppercase tracking-wider font-semibold font-mono">07. Further Reading</h2>
        <div class="flex flex-col gap-2">
          <a href="/writing/linux-network-security" class="text-[#2563EB] hover:underline">Article: Linux Network Security & Port Monitoring</a>
          <a href="/notes" class="text-[#2563EB] hover:underline">Notes: TCP Sliding Window buffers</a>
        </div>
      </section>

    </div>

  </main>

  <Footer />

  <!-- TCP Handshake JS -->
  <script is:inline>
    const stepBtn = document.getElementById('step-btn');
    const resetBtn = document.getElementById('reset-btn');
    const clientState = document.getElementById('client-state');
    const serverState = document.getElementById('server-state');
    const packetArrow = document.getElementById('packet-arrow');
    const packetDetails = document.getElementById('packet-details');
    const terminalLog = document.getElementById('terminal-log');

    let currentStep = 0;
    const clientSeq = 1000;
    const serverSeq = 5000;

    const steps = [
      {
        action: "Client sends SYN",
        arrow: "Client ── SYN (Seq=1000) ──> Server",
        details: "Initiates session. SYN flag set. Client proposes Seq=1000.",
        cState: "SYN_SENT",
        sState: "LISTEN",
        log: ">>> [Client] Sending TCP SYN segment: Seq=1000, ACK=0, Flags=[SYN]"
      },
      {
        action: "Server replies SYN-ACK",
        arrow: "Client <── SYN-ACK (Seq=5000, Ack=1001) ── Server",
        details: "Server acknowledges Client Seq+1. Server proposes Seq=5000.",
        cState: "SYN_SENT",
        sState: "SYN_RECEIVED",
        log: "<<< [Server] Received SYN. Replying SYN-ACK segment: Seq=5000, ACK=1001, Flags=[SYN, ACK]"
      },
      {
        action: "Client sends ACK",
        arrow: "Client ── ACK (Seq=1001, Ack=5001) ──> Server",
        details: "Handshake complete. Client acknowledges Server Seq+1.",
        cState: "ESTABLISHED",
        sState: "ESTABLISHED",
        log: ">>> [Client] Received SYN-ACK. Replying ACK segment: Seq=1001, ACK=5001, Flags=[ACK]\n[System] TCP Connection established successfully."
      },
      {
        action: "Data Transfer",
        arrow: "Client ── PSH-ACK (Seq=1001, Len=150) ──> Server",
        details: "Transmitting HTTP Request payload (150 bytes).",
        cState: "ESTABLISHED",
        sState: "ESTABLISHED",
        log: ">>> [Client] Sending Data: Seq=1001, ACK=5001, Len=150, Flags=[PSH, ACK]\n<<< [Server] Replying ACK: Seq=5001, ACK=1151, Flags=[ACK]"
      },
      {
        action: "Client starts FIN",
        arrow: "Client ── FIN-ACK (Seq=1151) ──> Server",
        details: "Initiates socket termination sequence.",
        cState: "FIN_WAIT_1",
        sState: "ESTABLISHED",
        log: ">>> [Client] Initiating connection close: Sending FIN-ACK: Seq=1151, ACK=5001, Flags=[FIN, ACK]"
      },
      {
        action: "Server acknowledges FIN",
        arrow: "Client <── ACK (Seq=5001, Ack=1152) ── Server",
        details: "Server acknowledges Client FIN. Server closes application read path.",
        cState: "FIN_WAIT_2",
        sState: "CLOSE_WAIT",
        log: "<<< [Server] Received FIN. Sending ACK: Seq=5001, ACK=1152, Flags=[ACK]"
      },
      {
        action: "Server sends FIN",
        arrow: "Client <── FIN-ACK (Seq=5001) ── Server",
        details: "Server closes application write path.",
        cState: "TIME_WAIT",
        sState: "LAST_ACK",
        log: "<<< [Server] Sending final FIN segment: Seq=5001, ACK=1152, Flags=[FIN, ACK]"
      },
      {
        action: "Client sends final ACK",
        arrow: "Client ── ACK (Seq=1152, Ack=5002) ──> Server",
        details: "Client enters TIME_WAIT buffer for 2MSL (usually 2-4 minutes).",
        cState: "TIME_WAIT",
        sState: "CLOSED",
        log: ">>> [Client] Replying final ACK segment: Seq=1152, ACK=5002, Flags=[ACK]\n<<< [Server] Received final ACK. Socket closed."
      },
      {
        action: "Socket Closed",
        arrow: "[ Socket Closed ]",
        details: "TIME_WAIT expires. Port released to system.",
        cState: "CLOSED",
        sState: "CLOSED",
        log: "[System] Client TIME_WAIT expired. Socket port released back to OS kernel."
      }
    ];

    function updateSim() {
      if (currentStep < steps.length) {
        const step = steps[currentStep];
        packetArrow.textContent = step.arrow;
        packetDetails.textContent = step.details;
        clientState.textContent = step.cState;
        serverState.textContent = step.sState;
        
        // Add color indicators
        if (step.cState === "ESTABLISHED") {
          clientState.className = "text-green-400";
        } else if (step.cState === "CLOSED") {
          clientState.className = "text-red-400";
        } else {
          clientState.className = "text-yellow-400";
        }

        if (step.sState === "ESTABLISHED") {
          serverState.className = "text-green-400";
        } else if (step.sState === "CLOSED" || step.sState === "LISTEN") {
          serverState.className = "text-red-400";
        } else {
          serverState.className = "text-yellow-400";
        }

        terminalLog.innerHTML += `\n${step.log}`;
        terminalLog.scrollTop = terminalLog.scrollHeight;
        
        currentStep++;
        if (currentStep === steps.length) {
          stepBtn.textContent = "Done";
          stepBtn.disabled = true;
          stepBtn.className = "px-4 py-1.5 bg-[#27272A] text-[#71717A] rounded text-xs font-mono cursor-not-allowed";
        } else {
          stepBtn.textContent = `Step ${currentStep + 1} →`;
        }
      }
    }

    function resetSim() {
      currentStep = 0;
      packetArrow.textContent = "[ Ready ]";
      packetDetails.textContent = "Click Step Handshake to start";
      clientState.textContent = "CLOSED";
      clientState.className = "text-red-400";
      serverState.textContent = "LISTEN";
      serverState.className = "text-red-400";
      terminalLog.textContent = "[System] Socket listener running on port 80...\n[System] Click 'Step Handshake' to begin.";
      stepBtn.textContent = "Step Handshake →";
      stepBtn.disabled = false;
      stepBtn.className = "px-4 py-1.5 bg-[#2563EB] text-white rounded text-xs hover:bg-[#1d4ed8] font-mono transition-colors";
    }

    stepBtn.addEventListener('click', updateSim);
    resetBtn.addEventListener('click', resetSim);
  </script>
</Layout>
