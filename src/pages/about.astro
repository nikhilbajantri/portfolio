---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

const timelineItems = [
  {
    period: "2024 - Present",
    role: "Core Software Engineering",
    details: "Focusing on backend systems and concurrency coordination. Contributing to DailyDine's scheduling backend."
  },
  {
    period: "2023 - 2024",
    role: "Open Source and Linux Fundamentals",
    details: "Began contributing to student developer groups. Focused on mastering Linux command line and system administration."
  },
  {
    period: "2021 - 2023",
    role: "Initial Programming and Exploration",
    details: "Explored programming fundamentals. Focused on basic data structures, algorithms, and script automation."
  }
];
---

<Layout title="About">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[960px] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-20 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6 max-w-[68ch]">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        About
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        A record of philosophies, operating workflows, and learning logs that guide my growth as an engineer.
      </p>
    </header>

    <!-- 1. Why I Build -->
    <section class="flex flex-col gap-4 max-w-[68ch]">
      <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        Why I Build
      </h2>
      <div class="flex flex-col gap-6 text-sm text-[#A1A1AA] leading-[1.7]">
        <p>
          I started programming because I wanted to understand how computers actually work.
          The ability to instruct silicon to coordinate data remains fascinating to me.
          I believe that software engineering is a craft requiring patience, humility, and continuous study.
        </p>
        <p>
          I aim to design software that is quiet, reliable, and built to survive.
          I prefer to reduce systems to their absolute essentials to ensure they are easy to debug.
          Writing down my errors and lessons in public helps clarify my understanding of systems.
        </p>
      </div>
    </section>

    <!-- 2. What I'm Curious About -->
    <section class="flex flex-col gap-4 max-w-[68ch]">
      <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        What I'm Curious About
      </h2>
      <div class="flex flex-col gap-6 text-sm text-[#A1A1AA] leading-[1.7]">
        <p>
          I am currently studying systems security, distributed systems, and compiler design.
          I focus on learning cybersecurity protocols, cryptographic architectures, and memory models.
          I spend time reading RFCs and system manuals to understand networking layers.
        </p>
      </div>
    </section>

    <!-- 3. The Principles I Return To -->
    <section class="flex flex-col gap-4 max-w-[68ch]">
      <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        The Principles I Return To
      </h2>
      <div class="flex flex-col gap-4 text-sm text-[#A1A1AA] leading-[1.7]">
        <p>
          I return to core principles whenever I face architectural complexity.
          These guide my trade-off decisions and keep code maintainable.
        </p>
        <ul class="flex flex-col gap-2 list-disc pl-4 text-xs text-[#71717A]">
          <li>Value simplicity and correctness over developer convenience.</li>
          <li>Every dependency added is a potential point of failure.</li>
          <li>Understand foundational mechanics rather than memorizing syntax.</li>
        </ul>
        <div class="pt-2">
          <a href="/principles" class="text-xs text-[#2563EB] hover:underline font-medium">Read all principles →</a>
        </div>
      </div>
    </section>

    <!-- 4. How I Learn (Operating Manual) -->
    <section class="flex flex-col gap-6">
      <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        How I Learn
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div class="flex flex-col gap-2">
          <h3 class="text-sm font-medium text-[#FAFAFA]">Focus Over Noise</h3>
          <p class="text-sm text-[#A1A1AA] leading-relaxed">
            I block off dedicated focus windows to study technical manuals.
            I avoid constant context switching to allow deep comprehension.
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <h3 class="text-sm font-medium text-[#FAFAFA]">Verify in Labs</h3>
          <p class="text-sm text-[#A1A1AA] leading-relaxed">
            I write tiny, isolated scripts to verify how network sockets or buffers behave.
            Verification prevents assumptions about library behavior.
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <h3 class="text-sm font-medium text-[#FAFAFA]">Read Documentation First</h3>
          <p class="text-sm text-[#A1A1AA] leading-relaxed">
            I read raw documentation and specification sheets rather than tutorials.
            Going to the source material yields complete, unbiased technical clarity.
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <h3 class="text-sm font-medium text-[#FAFAFA]">Document Errors</h3>
          <p class="text-sm text-[#A1A1AA] leading-relaxed">
            I keep logs of errors made during debugging.
            This practice prevents repeating identical architectural mistakes.
          </p>
        </div>
      </div>
    </section>

    <!-- 5. Looking Back -->
    <section class="flex flex-col gap-6">
      <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        Looking Back
      </h2>
      <div class="flex flex-col gap-8">
        {timelineItems.map((item) => (
          <div class="flex flex-col sm:flex-row gap-2 sm:gap-12">
            <span class="text-xs text-[#71717A] font-mono sm:w-28 flex-shrink-0">{item.period}</span>
            <div class="flex flex-col gap-1">
              <h3 class="text-sm font-medium text-[#FAFAFA]">{item.role}</h3>
              <p class="text-sm text-[#A1A1AA] leading-relaxed max-w-[68ch]">{item.details}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 6. Résumé Reference -->
    <section class="flex flex-col gap-4 max-w-[68ch]">
      <h2 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        Résumé
      </h2>
      <p class="text-sm text-[#A1A1AA] leading-relaxed">
        I maintain a dedicated resume page detailing professional projects, skills, education, and credentials.
      </p>
      <div>
        <a href="/about/resume" class="text-xs text-[#2563EB] hover:underline font-medium">View full résumé →</a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
