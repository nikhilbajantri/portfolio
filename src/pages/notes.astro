---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { getNotes } from "../lib/content";

const notes = await getNotes();
---

<Layout title="Notes">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[68ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-12 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-4">
      <h1 class="text-4xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Notes
      </h1>
      <p class="text-base text-[#A1A1AA] leading-relaxed">
        Single-topic engineering logs, command logs, and systems observations.
      </p>
    </header>

    <!-- Notes list -->
    <div class="flex flex-col gap-12">
      {notes.map((note) => (
        <section class="flex flex-col gap-3">
          <div class="flex justify-between items-baseline gap-4">
            <h2 class="text-xl font-display font-medium text-[#FAFAFA] tracking-tight">
              <a href={`/notes/${note.slug}`} class="hover:text-[#2563EB] transition-colors">
                {note.data.title}
              </a>
            </h2>
            <span class="text-xs text-[#71717A] font-mono whitespace-nowrap">
              {new Date(note.data.date).toLocaleDateString("en-US", { year: "numeric", month: "short" })}
            </span>
          </div>
          <p class="text-xs text-[#71717A] font-mono uppercase tracking-wider">
            Topic: {note.data.topic} · {note.data.difficulty}
          </p>
          <p class="text-sm text-[#A1A1AA] leading-relaxed mt-1">
            {note.data.summary}
          </p>
        </section>
      ))}
    </div>

  </main>

  <Footer />
</Layout>
