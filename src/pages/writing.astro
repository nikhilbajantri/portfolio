---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { getArticles } from "../lib/content";

const articles = await getArticles();
---

<Layout title="Writing">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[960px] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6 max-w-[68ch]">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Writing
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        Deep dives, essays, and notes on software engineering, distributed systems, networking, and security.
      </p>
    </header>

    <!-- Articles List -->
    <div class="flex flex-col gap-12">
      {articles.map((post) => (
        <article class="flex flex-col gap-2 max-w-[680px]">
          <div class="flex justify-between items-baseline gap-4">
            <h2 class="text-lg font-medium text-[#FAFAFA]">
              <a href={`/writing/${post.slug}`} class="hover:text-[#2563EB] transition-colors duration-180">
                {post.data.title}
              </a>
            </h2>
            <span class="text-xs text-[#71717A] font-mono whitespace-nowrap">
              {new Date(post.data.published).toLocaleDateString("en-US", { year: "numeric", month: "short" })}
            </span>
          </div>
          <span class="text-xs text-[#71717A] font-mono uppercase tracking-wider">{post.data.category}</span>
          <p class="text-sm text-[#A1A1AA] leading-relaxed mt-1">
            {post.data.description}
          </p>
        </article>
      ))}
    </div>

  </main>

  <Footer />
</Layout>
