---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

const categories = [
  {
    title: "Hardware",
    items: [
      { name: "LOQ Ryzen 7", desc: "Main development laptop. Quiet, reliable, and capable of running heavy compilations." },
      { name: "Xiaomi Pad 5", desc: "Digital notepad and reader used for studying system manuals on the go." },
      { name: "Realme 12 Pro", desc: "Physical testing device for mobile software builds." }
    ]
  },
  {
    title: "Development",
    items: [
      { name: "Cursor / Neovim", desc: "Default editors. Fast, distraction-free environment containing autocomplete capabilities." },
      { name: "Brave Browser", desc: "Default Web browser. Safe browsing with robust tracker blocking." },
      { name: "Git", desc: "Decentralized version control system ensuring full code history ownership." }
    ]
  },
  {
    title: "Security Workflow",
    items: [
      { name: "1Password", desc: "Encrypted password storage for credentials." },
      { name: "GnuPG", desc: "Sign commits and encrypt communication keys." }
    ]
  }
];
---

<Layout title="Uses">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[72ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Uses
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        Why I Use These Tools: I optimize for tools that disappear into the background.
        The best software lets me focus on thinking rather than configuration.
      </p>
    </header>

    <!-- Specs Lists -->
    <div class="flex flex-col gap-12">
      {categories.map((cat) => (
        <section class="flex flex-col gap-4">
          <h2 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
            {cat.title}
          </h2>
          <ul class="flex flex-col gap-4">
            {cat.items.map((item) => (
              <li class="flex flex-col gap-1">
                <span class="text-sm font-medium text-[#FAFAFA]">{item.name}</span>
                <span class="text-sm text-[#A1A1AA] leading-relaxed">{item.desc}</span>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

  </main>

  <Footer />
</Layout>
