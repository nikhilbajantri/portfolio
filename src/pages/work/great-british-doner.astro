---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Great British Doner Case Study">
  <Navigation />

  <!-- Scroll progress bar script -->
  <div class="fixed top-0 left-0 w-full h-1 bg-[#2563EB]/10 z-50">
    <div id="scroll-indicator" class="h-full bg-[#2563EB] w-0 transition-all duration-100"></div>
  </div>

  <main id="main-content" class="flex-1 max-w-[1200px] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-12 font-sans relative">
    
    <!-- Top Bar Navigation & Progress Indicator -->
    <div class="flex justify-between items-center text-xs text-[#71717A] font-mono border-b border-[rgba(255,255,255,0.06)] pb-4">
      <a href="/work" class="hover:text-[#FAFAFA] transition-colors">← Back to Work</a>
      <div class="flex items-center gap-4">
        <span>Estimated Reading Time: 9 min</span>
        <span id="progress-text" class="text-white">██████░░░░░░ 0%</span>
      </div>
    </div>

    <!-- Header Section -->
    <header class="flex flex-col gap-4 max-w-[68ch]">
      <div class="flex gap-2 text-xs text-[#71717A] font-mono uppercase tracking-wider">
        <span>Selected Work</span>
        <span>·</span>
        <span>2025</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-tight">
        Great British Doner: Headless CMS
      </h1>
      <p class="text-base text-[#A1A1AA] leading-relaxed">
        A headless restaurant website built to improve content workflows, SEO, and performance.
      </p>
    </header>

    <!-- Snapshot Widget Grid -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-8 border-y border-[rgba(255,255,255,0.06)] py-8 my-4 text-xs font-mono text-[#A1A1AA]">
      
      <!-- Project at a Glance -->
      <div class="flex flex-col gap-3">
        <h4 class="text-[#FAFAFA] font-sans font-medium uppercase tracking-wider text-[11px]">Project at a Glance</h4>
        <div class="flex flex-col gap-1.5">
          <div>Role: <span class="text-white">Software Engineer</span></div>
          <div>Duration: <span class="text-white">Duration: 3 Months</span></div>
          <div>Status: <span class="text-white">● Production</span></div>
          <div>Team: <span class="text-white">1 Engineer</span></div>
        </div>
      </div>

      <!-- Scale -->
      <div class="flex flex-col gap-3">
        <h4 class="text-[#FAFAFA] font-sans font-medium uppercase tracking-wider text-[11px]">Scale</h4>
        <div class="flex flex-col gap-1.5">
          <div>Users: <span class="text-white">Production</span></div>
          <div>Traffic: <span class="text-white">Production</span></div>
          <div>Deployment: <span class="text-white">Cloud</span></div>
          <div>Repository: <span class="text-white">Client-owned</span></div>
        </div>
      </div>

      <!-- Principles Applied -->
      <div class="flex flex-col gap-3">
        <h4 class="text-[#FAFAFA] font-sans font-medium uppercase tracking-wider text-[11px]">Principles Applied</h4>
        <div class="flex flex-col gap-1.5">
          <div>✓ Simplicity over abstraction</div>
          <div>✓ Consistency before scalability</div>
          <div>✓ Documentation-first</div>
          <div>✓ Measure before optimizing</div>
        </div>
      </div>

    </section>

    <!-- Key Takeaway Highlight Block -->
    <div class="border-l-2 border-[#2563EB] pl-6 py-1 max-w-[68ch]">
      <h4 class="text-xs text-[#71717A] uppercase tracking-wider font-semibold mb-2 font-mono">What did this project teach me?</h4>
      <p class="text-sm text-[#FAFAFA] leading-relaxed italic">
        "This project fundamentally changed how I think about static site generation, structured headless content models, and SEO performance optimization."
      </p>
    </div>

    <!-- Layout Grid: Sticky TOC on left (Desktop), Main content on right -->
    <div class="flex flex-col lg:flex-row gap-12 mt-6">
      
      <!-- Sticky Sidebar (TOC) -->
      <aside class="w-full lg:w-48 lg:shrink-0 lg:sticky lg:top-24 h-fit flex flex-col gap-4 font-mono text-xs text-[#71717A]">
        <span class="text-[#FAFAFA] font-sans font-medium uppercase tracking-wider text-[10px]">Chapters</span>
        <ul class="flex flex-row lg:flex-col gap-4 lg:gap-2 overflow-x-auto pb-2 lg:pb-0">
          <li><a href="#overview" class="hover:text-white transition-colors">01. Overview</a></li>
          <li><a href="#engineering" class="hover:text-white transition-colors">02. Engineering</a></li>
          <li><a href="#reflection" class="hover:text-white transition-colors">03. Reflection</a></li>
          <li><a href="#resources" class="hover:text-white transition-colors">04. Resources</a></li>
        </ul>
      </aside>

      <!-- Main Case Study Content -->
      <div class="flex-1 max-w-[68ch] flex flex-col gap-16 text-base text-[#FAFAFA] leading-[1.7] tracking-tight font-normal">
        
        <!-- CHAPTER 1: OVERVIEW -->
        <section id="overview" class="flex flex-col gap-8 scroll-mt-24">
          <h2 class="text-2xl font-display font-medium border-b border-[rgba(255,255,255,0.06)] pb-2 text-[#FAFAFA]">
            01. Overview
          </h2>

          <div class="flex flex-col gap-6">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Executive Summary</h3>
            <p class="text-sm text-[#A1A1AA]">
              Great British Doner is a headless restaurant website built to improve content management workflows, search engine visibility (SEO), and page load performance. The project details the migration of a legacy monolithic site to a headless Sanity CMS and Next.js static architecture. By utilizing structured content schemas and automated incremental static regeneration (ISR), the system delivers sub-second page loads and fast menu updates.
            </p>

            <h4 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Key Takeaways</h4>
            <ul class="list-disc pl-5 text-sm text-[#A1A1AA] flex flex-col gap-2">
              <li>Migrated a legacy site to a headless static architecture.</li>
              <li>Secured sub-second page rendering using static generation.</li>
              <li>Simplified content editing workflows for restaurant administrators.</li>
            </ul>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Context</h3>
            <p>
              Great British Doner is a local restaurant brand.
              The operations team requires quick updates to menus, hours, and banners without edit latency or coding knowledge.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">The Problem</h3>
            <p>
              The legacy site had slow load times, poor SEO indexing, and required code changes for simple price edits.
              This restricted marketing campaigns and reduced mobile ordering rates.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Why It Mattered</h3>
            <p>
              Fast loading speeds on mobile devices directly correlate with restaurant conversion and ordering rates.
              Unoptimized images and slow servers impact customer conversion.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Research</h3>
            <p>
              We researched maintaining the monolithic database stack.
              However, serving dynamic queries for static menus is expensive and introduces database wait times that degrade SEO rankings.
            </p>
          </div>
        </section>

        <!-- CHAPTER 2: ENGINEERING -->
        <section id="engineering" class="flex flex-col gap-8 scroll-mt-24">
          <h2 class="text-2xl font-display font-medium border-b border-[rgba(255,255,255,0.06)] pb-2 text-[#FAFAFA]">
            02. Engineering
          </h2>

          <!-- Architecture scan list -->
          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Architecture</h3>
            <div class="flex flex-col gap-1.5 text-xs font-mono text-[#A1A1AA] bg-[#111113] p-4 rounded-xl border border-[rgba(255,255,255,0.04)]">
              <div>CMS Studio: Sanity CMS</div>
              <div class="text-[#71717A]">↓</div>
              <div>Static Compiler: Next.js (ISR)</div>
              <div class="text-[#71717A]">↓</div>
              <div>Asset Optimization: Vercel CDN</div>
              <div class="text-[#71717A]">↓</div>
              <div>Analytics: Privacy-first edge tracking</div>
            </div>
          </div>

          <!-- Architecture SVG Flowchart -->
          <div class="flex flex-col gap-3 bg-[#111113] border border-[rgba(255,255,255,0.04)] p-6 rounded-xl">
            <h4 class="text-[11px] font-mono text-[#71717A] uppercase">CMS Deploy Pipeline</h4>
            <svg viewBox="0 0 400 180" class="w-full h-auto text-white">
              <rect x="10" y="25" width="80" height="30" rx="4" fill="#18181B" stroke="#27272A" stroke-width="1.5" />
              <text x="50" y="43" text-anchor="middle" font-size="9" fill="#FAFAFA" font-family="monospace">Sanity Editor</text>
              
              <rect x="160" y="25" width="80" height="30" rx="4" fill="#18181B" stroke="#27272A" stroke-width="1.5" />
              <text x="200" y="43" text-anchor="middle" font-size="9" fill="#FAFAFA" font-family="monospace">Vercel Webhook</text>
              
              <rect x="310" y="25" width="80" height="30" rx="4" fill="#18181B" stroke="#27272A" stroke-width="1.5" />
              <text x="350" y="43" text-anchor="middle" font-size="9" fill="#FAFAFA" font-family="monospace">Next.js ISR</text>

              <path d="M50 55 v100" stroke="#27272A" stroke-width="1" stroke-dasharray="2" />
              <path d="M200 55 v100" stroke="#27272A" stroke-width="1" stroke-dasharray="2" />
              <path d="M350 55 v100" stroke="#27272A" stroke-width="1" stroke-dasharray="2" />

              <path d="M50 75 h150" stroke="#2563EB" stroke-width="1.5" marker-end="url(#arrow)" />
              <text x="125" y="70" text-anchor="middle" font-size="8" fill="#71717A" font-family="monospace">Publish Menu</text>

              <path d="M200 95 h150" stroke="#2563EB" stroke-width="1.5" marker-end="url(#arrow)" />
              <text x="275" y="90" text-anchor="middle" font-size="8" fill="#71717A" font-family="monospace">Trigger ISR Build</text>

              <path d="M350 120 h-150" stroke="#2563EB" stroke-width="1.5" marker-end="url(#arrow)" />
              <text x="275" y="115" text-anchor="middle" font-size="8" fill="#71717A" font-family="monospace">Purge Static Cache</text>

              <path d="M200 140 h-150" stroke="#2563EB" stroke-width="1.5" marker-end="url(#arrow)" />
              <text x="125" y="135" text-anchor="middle" font-size="8" fill="#71717A" font-family="monospace">Sync Complete</text>
            </svg>
          </div>

          <!-- Key Decisions with chronology -->
          <div class="flex flex-col gap-6">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Key Decisions</h3>
            
            <div class="flex flex-col gap-4 pl-4 border-l border-[rgba(255,255,255,0.06)]">
              <div>
                <span class="text-xs text-[#71717A] font-mono block mb-1">March 2025 · Headless Sanity over WordPress</span>
                <div class="text-sm font-medium text-white">Decision: Sanity CMS schemas.</div>
                <p class="text-xs text-[#A1A1AA] mt-1">Sanity provides structured JSON menus, preventing editors from breaking layout designs through rich-text fields.</p>
              </div>
              
              <div>
                <span class="text-xs text-[#71717A] font-mono block mb-1">April 2025 · Incremental Static Regeneration</span>
                <div class="text-sm font-medium text-white">Decision: Next.js ISR compilation.</div>
                <p class="text-xs text-[#A1A1AA] mt-1">Rather than rebuild the entire site for single price edits, ISR updates individual static paths on-demand.</p>
              </div>
            </div>
          </div>

          <!-- Trade-offs 3-column table -->
          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Trade-offs</h3>
            <div class="overflow-x-auto">
              <table class="w-full text-left text-xs font-mono border-collapse">
                <thead>
                  <tr class="border-b border-[rgba(255,255,255,0.08)] text-[#71717A]">
                    <th class="py-2 pr-4 font-semibold">Decision</th>
                    <th class="py-2 px-4 font-semibold">Benefit</th>
                    <th class="py-2 pl-4 font-semibold">Cost</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-[rgba(255,255,255,0.04)] text-[#A1A1AA]">
                  <tr>
                    <td class="py-3 pr-4 font-medium text-[#FAFAFA]">Static Generation</td>
                    <td class="py-3 px-4">Fast loading speeds</td>
                    <td class="py-3 pl-4">Rebuild queue latency</td>
                  </tr>
                  <tr>
                    <td class="py-3 pr-4 font-medium text-[#FAFAFA]">Sanity CMS</td>
                    <td class="py-3 px-4">Structured content data</td>
                    <td class="py-3 pl-4">Separate dashboard logins</td>
                  </tr>
                  <tr>
                    <td class="py-3 pr-4 font-medium text-[#FAFAFA]">Vercel Edge Caching</td>
                    <td class="py-3 px-4">Sub-second global TTFB</td>
                    <td class="py-3 pl-4">Cache invalidation checks</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">What Didn't Work</h3>
            <p>
              Our initial setup fetched images directly from the CMS CDN without size optimization.
              This bloated page sizes on mobile.
              We replaced this with Next.js dynamic image transcoding layers to ensure optimal image delivery.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Security</h3>
            <p>
              We secured the CMS webhook validations using custom header signature audits, preventing spoofed deploy triggers.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Performance</h3>
            <p>
              By migrating to static builds, we achieved clean performance metrics: Lighthouse scores rose to 98, and static build times fell to 12 seconds.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Monitoring</h3>
            <p>
              Aggregated build reports and webhook error logs are monitored directly on the deployment platform.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Scalability</h3>
            <p>
              Serving static pages from CDN edge nodes scales to handle traffic peaks seamlessly, without application database load.
            </p>
          </div>
        </section>

        <!-- CHAPTER 3: REFLECTION -->
        <section id="reflection" class="flex flex-col gap-8 scroll-mt-24">
          <h2 class="text-2xl font-display font-medium border-b border-[rgba(255,255,255,0.06)] pb-2 text-[#FAFAFA]">
            03. Reflection
          </h2>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Outcome</h3>
            <p>
              Great British Doner operates stably, rendering menu variations instantly and handling traffic peaks without server overload.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Lessons</h3>
            <p>
              Migrating to static pages eliminates database wait times for content sites, optimizing search engine indexes.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Things I'd Do Differently</h3>
            <ul class="list-disc pl-5 text-sm text-[#A1A1AA] flex flex-col gap-1.5">
              <li>Define the CMS structured schema early in the project.</li>
              <li>Configure image aspect ratios at the model boundary.</li>
              <li>Incorporate SEO meta tags early in the layout designs.</li>
            </ul>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">If I Rebuilt It Today</h3>
            <p>
              If I restarted, I would explore Astro to reduce JavaScript client bundle weight.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Questions I'm Still Exploring</h3>
            <ul class="list-disc pl-5 text-sm text-[#A1A1AA] flex flex-col gap-1.5">
              <li>Can edge-dynamic layouts customize menus by user location without database latencies?</li>
              <li>How will automated layout tests prevent schema mismatch failures?</li>
            </ul>
          </div>
        </section>

        <!-- CHAPTER 4: RESOURCES -->
        <section id="resources" class="flex flex-col gap-8 scroll-mt-24">
          <h2 class="text-2xl font-display font-medium border-b border-[rgba(255,255,255,0.06)] pb-2 text-[#FAFAFA]">
            04. Resources
          </h2>

          <!-- Revision History -->
          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Revision History</h3>
            <div class="flex flex-col gap-4 text-xs font-mono text-[#A1A1AA] pl-4 border-l border-[rgba(255,255,255,0.06)]">
              <div>
                <span class="text-[#71717A] block mb-0.5">July 2026</span>
                Initial case study publication.
              </div>
            </div>
          </div>

          <!-- Downloads -->
          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Downloads</h3>
            <div class="flex flex-wrap gap-4 text-xs font-mono">
              <a href="#" class="text-[#2563EB] hover:underline">Deploy Pipeline (SVG)</a>
            </div>
          </div>

          <!-- Further Reading -->
          <div class="flex flex-col gap-4 border-t border-[rgba(255,255,255,0.06)] pt-6">
            <h3 class="text-xs font-semibold text-[#71717A] uppercase tracking-wider font-mono">Further Reading</h3>
            <div class="flex flex-col gap-2 text-sm">
              <a href="/writing/why-i-built-this-website" class="text-[#2563EB] hover:underline">Related Writing: Why I Built This Website</a>
              <a href="/notes" class="text-[#2563EB] hover:underline">Related Notes: CMS migrations</a>
              <a href="https://github.com/programmer-nick234/gbd" target="_blank" rel="noopener noreferrer" class="text-[#2563EB] hover:underline">Source Code: GitHub Repository</a>
            </div>
          </div>

          <!-- Technical Stack (mono, last) -->
          <div class="flex flex-col gap-2 text-xs font-mono text-[#71717A] border-t border-[rgba(255,255,255,0.06)] pt-6">
            <span>Technologies: Next.js · Sanity CMS · Vercel · Tailwind CSS</span>
          </div>
        </section>

      </div>

    </div>

  </main>

  <Footer />

  <!-- Scroll and Reading Progress Logic -->
  <script is:inline>
    const scrollIndicator = document.getElementById('scroll-indicator');
    const progressText = document.getElementById('progress-text');

    window.addEventListener('scroll', () => {
      const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = height > 0 ? Math.round((winScroll / height) * 100) : 0;
      
      scrollIndicator.style.width = scrolled + '%';
      
      const totalBlocks = 12;
      const filledBlocks = Math.round((scrolled / 100) * totalBlocks);
      const emptyBlocks = totalBlocks - filledBlocks;
      const progressBlocks = '█'.repeat(filledBlocks) + '░'.repeat(emptyBlocks);
      
      progressText.textContent = `${progressBlocks} ${scrolled}%`;
    });
  </script>
</Layout>
