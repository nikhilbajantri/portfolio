---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

// Highlighted Case Studies
const highlightedWork = [
  {
    title: "DailyDine",
    subtitle: "Dining coordination platform",
    overview: "DailyDine coordinates table reservations for local restaurants, focusing on scheduling reliability.",
    challenge: "Balancing table inventory with customer convenience under high reservation concurrency.",
    approach: "Designed an event-driven lock system to prevent overbooking during peak dining hours.",
    architecture: "React frontend communicating with a Go backend and a PostgreSQL database.",
    tradeoffs: "Chose server-side polling instead of WebSockets to reduce state management complexity on the server.",
    outcome: "Coordinated reservations across three venues, reducing customer wait times.",
    lessons: "Simple database transactions are easier to maintain than distributed reservation state machines.",
    tech: ["Go", "React", "PostgreSQL", "Tailwind CSS"],
    slug: "/work/dailydine"
  },
  {
    title: "HisabProx",
    subtitle: "Local invoice utility",
    overview: "HisabProx helps freelance developers generate and manage client invoices without external database storage.",
    challenge: "Ensuring developer data privacy without hosting expensive cloud database infrastructure.",
    approach: "Built a client-side storage utility that runs completely locally in the browser.",
    architecture: "Static TypeScript app utilizing local storage and client-side PDF compilation.",
    tradeoffs: "Traded multi-device synchronization for complete client privacy and zero server maintenance costs.",
    outcome: "Active local utility used to draft and compile PDF invoices daily.",
    lessons: "The most secure and cost-effective system is the one that avoids storing data on a remote server.",
    tech: ["TypeScript", "React", "Local Storage", "PDFKit"],
    slug: "/work/hisabprox"
  }
];

// Latest Writing Highlights
const latestWriting = [
  {
    title: "Why I Started Writing",
    category: "Essay",
    date: "July 2026",
    description: "An inquiry into how writing helps clarify software architecture and structures memory.",
    slug: "/writing/why-i-started-writing"
  },
  {
    title: "The Kind of Engineer I Want to Become",
    category: "Essay",
    date: "June 2026",
    description: "Reflections on craftsman philosophy, engineering humility, and long-term design patterns.",
    slug: "/writing/the-kind-of-engineer-i-want-to-become"
  }
];
---
<Layout title="nikhilbajantri.dev">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[960px] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-32 font-sans">
    
    <!-- 1. Hero Section -->
    <section id="hero" class="flex flex-col pt-8 pb-20 sm:pt-10 sm:pb-24">
      <span class="text-xs font-mono text-[#71717A] uppercase tracking-widest mb-6">Nikhil Bajantri</span>
      <h1 class="text-5xl sm:text-7xl lg:text-[104px] font-display font-medium text-[#FAFAFA] tracking-tight leading-none mb-12">
        Build. Learn. Write.
      </h1>
      <p class="text-lg sm:text-xl lg:text-[20px] text-[#A1A1AA] leading-[1.7] max-w-[65ch] mb-8">
        Technology changes quickly. Good ideas don't. I use this website to explore software engineering, cybersecurity, systems, and the habits that help me become a better builder over time.
      </p>
      <blockquote class="border-l border-[#2563EB] pl-6 py-1 text-sm sm:text-base text-[#71717A] leading-[1.7] max-w-[65ch] italic mb-8">
        I don't write because I know. I write because it helps me understand. This website isn't a record of expertise. It's a record of progress.
      </blockquote>
      <div class="flex flex-col gap-1.5 text-xs sm:text-sm text-[#71717A] leading-relaxed max-w-[65ch]">
        <p>Expect engineering notes, book reviews, project breakdowns, and lessons learned along the way.</p>
        <p class="italic text-[#A1A1AA]/70">Currently building DailyDine and learning cybersecurity one rabbit hole at a time.</p>
      </div>
    </section>

    <!-- 2. Now (Current Focus) Section -->
    <section id="now" class="flex flex-col gap-8 border-t border-[rgba(255,255,255,0.08)] pt-16">
      <div class="flex justify-between items-baseline">
        <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">Now</h2>
        <a href="/now" class="text-xs text-[#2563EB] hover:underline font-medium">Browse details →</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        <!-- Building Card -->
        <div class="p-6 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-2">
          <span class="text-xs text-[#71717A] uppercase tracking-wider font-semibold">Building</span>
          <h3 class="text-sm font-medium text-[#FAFAFA]">DailyDine</h3>
          <p class="text-xs text-[#A1A1AA] leading-relaxed">
            A restaurant platform exploring better dining experiences through thoughtful software.
          </p>
        </div>

        <!-- Learning Card -->
        <div class="p-6 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-2">
          <span class="text-xs text-[#71717A] uppercase tracking-wider font-semibold">Learning</span>
          <h3 class="text-sm font-medium text-[#FAFAFA]">Cybersecurity & Systems</h3>
          <p class="text-xs text-[#A1A1AA] leading-relaxed">
            Studying distributed systems architecture, compiled languages, and Linux network security patterns.
          </p>
        </div>

        <!-- Reading Card -->
        <div class="p-6 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-2">
          <span class="text-xs text-[#71717A] uppercase tracking-wider font-semibold">Reading</span>
          <h3 class="text-sm font-medium text-[#FAFAFA]">The Pragmatic Programmer</h3>
          <p class="text-xs text-[#A1A1AA] leading-relaxed">
            42% complete · Started 3 days ago.
          </p>
          <div class="mt-2 border-t border-[rgba(255,255,255,0.04)] pt-2 flex flex-col gap-1">
            <span class="text-[#71717A] block font-mono text-[9px] uppercase tracking-wider">One idea that stood out</span>
            <span class="text-[#FAFAFA] italic text-xs">"Care about your craft."</span>
          </div>
        </div>

        <!-- Writing Card -->
        <div class="p-6 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-2">
          <span class="text-xs text-[#71717A] uppercase tracking-wider font-semibold">Writing</span>
          <h3 class="text-sm font-medium text-[#FAFAFA]">Systems Notebook</h3>
          <p class="text-xs text-[#A1A1AA] leading-relaxed">
            Drafting notes on JWT Authentication mechanisms, Linux administration, and personal engineering logs.
          </p>
        </div>

      </div>
    </section>

    <!-- 3. Selected Work (Selected Case Studies) -->
    <section id="work" class="flex flex-col gap-8 border-t border-[rgba(255,255,255,0.08)] pt-12">
      <div class="flex justify-between items-baseline">
        <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">Work</h2>
        <a href="/work" class="text-xs text-[#2563EB] hover:underline font-medium">Explore</a>
      </div>

      <div class="flex flex-col gap-12">
        {highlightedWork.map((project) => (
          <article class="p-6 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-4">
            
            <div class="flex flex-col gap-1">
              <h3 class="text-lg font-medium text-[#FAFAFA]">{project.title}</h3>
              <p class="text-xs text-[#71717A] font-mono">{project.subtitle}</p>
            </div>

            <p class="text-sm text-[#A1A1AA] leading-relaxed">
              {project.overview}
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs text-[#A1A1AA] mt-2">
              <div>
                <span class="font-medium text-[#FAFAFA] block mb-1">Challenge</span>
                {project.challenge}
              </div>
              <div>
                <span class="font-medium text-[#FAFAFA] block mb-1">Architecture</span>
                {project.architecture}
              </div>
            </div>

            <div class="flex justify-between items-center mt-4 border-t border-[rgba(255,255,255,0.04)] pt-4">
              <span class="text-[11px] font-mono text-[#71717A]">
                {project.tech.join(" · ")}
              </span>
              <a href={project.slug} class="text-xs text-[#2563EB] hover:underline">
                View Case Study
              </a>
            </div>

          </article>
        ))}
      </div>
    </section>

    <!-- 4. Latest Writing Section -->
    <section id="writing" class="flex flex-col gap-8 border-t border-[rgba(255,255,255,0.08)] pt-12">
      <div class="flex justify-between items-baseline">
        <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">Writing</h2>
        <a href="/writing" class="text-xs text-[#2563EB] hover:underline font-medium">Browse articles →</a>
      </div>

      <div class="flex flex-col gap-6">
        {latestWriting.map((post) => (
          <a href={post.slug} class="group p-5 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-2 hover:border-[#2563EB]/40 transition-colors duration-180">
            <div class="flex justify-between items-baseline gap-2">
              <h3 class="text-base font-medium text-[#FAFAFA] group-hover:text-[#2563EB] transition-colors duration-180">
                {post.title}
              </h3>
              <span class="text-xs text-[#71717A] font-mono whitespace-nowrap">{post.date}</span>
            </div>
            <p class="text-sm text-[#A1A1AA] leading-relaxed line-clamp-2">
              {post.description}
            </p>
          </a>
        ))}
      </div>
    </section>

    <!-- 5. About (Brief Philosophy Summary) -->
    <section id="about" class="flex flex-col gap-6 border-t border-[rgba(255,255,255,0.08)] pt-12">
      <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">About</h2>
      
      <p class="text-sm sm:text-base text-[#A1A1AA] leading-relaxed max-w-[72ch]">
        I build software to solve real problems and write to make sense of what I learn. I believe engineering is a craft that requires patience, humility, and continuous learning. My focus is on studying computer systems, security, and building tools that make tomorrow's work easier than today's.
      </p>

      <div>
        <a href="/about" class="text-sm text-[#2563EB] hover:underline font-medium">
          Read More →
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
