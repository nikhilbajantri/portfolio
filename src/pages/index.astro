---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import Newsletter from "../components/Newsletter.astro";
import { getHomepage } from "../lib/content";

const homeData = await getHomepage();
const { hero, focus, featuredProjects, latestArticles, latestNotes, latestJourney } = homeData;

// Load homepage sections config
const configEntry = await getEntry("homepage", "config");
const widgets = configEntry?.data?.widgets || [
  { id: "hero", enabled: true, priority: 1 },
  { id: "focus", enabled: true, priority: 2 },
  { id: "projects", enabled: true, priority: 3 },
  { id: "writing", enabled: true, priority: 4 },
  { id: "reading", enabled: true, priority: 5 },
  { id: "newsletter", enabled: true, priority: 6 }
];

const activeWidgets = widgets
  .filter(w => w.enabled)
  .sort((a, b) => a.priority - b.priority);

// Format text metrics
const heroTitle = hero?.data?.title || "Build. Learn. Write.";
const heroDesc = hero?.data?.description || "I build software that reduces uncertainty, design predictable distributed architectures, and document my learning path in public.";
const focusTitle = focus?.data?.title || "Current Focus";
const focusDesc = focus?.data?.description || "Optimizing PostgreSQL transaction concurrency locks, auditing Linux socket parameters, and building reservation queue engines.";
---

<Layout title="nikhilbajantri.dev">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[960px] mx-auto px-6 pt-4 pb-16 sm:pt-6 sm:pb-24 flex flex-col gap-24 font-sans">
    
    {activeWidgets.map((widget) => {
      switch (widget.id) {
        case "hero":
          return (
            <section id="hero" class="flex flex-col pt-0 pb-4">
              <span class="text-xs font-mono text-[#71717A] uppercase tracking-widest mb-6">Nikhil Bajantri</span>
              <h1 class="text-5xl sm:text-7xl lg:text-[96px] font-display font-medium text-[#FAFAFA] tracking-tight leading-none mb-10">
                {heroTitle}
              </h1>
              <p class="text-lg text-[#A1A1AA] leading-relaxed max-w-[680px] mb-8">
                {heroDesc}
              </p>
              <div>
                <a href="/writing" class="text-xs text-[#2563EB] hover:underline font-mono">
                  Read the latest article &rarr;
                </a>
              </div>
            </section>
          );

        case "focus":
          return (
            <section id="now" class="flex flex-col gap-6 border-t border-[rgba(255,255,255,0.06)] pt-12">
              <div class="flex justify-between items-baseline">
                <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">{focusTitle}</h2>
                <a href="/now" class="text-xs text-[#2563EB] hover:underline font-medium">Browse details &rarr;</a>
              </div>
              <div class="p-6 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-2">
                <span class="text-xs text-[#71717A] uppercase tracking-wider font-semibold">Active Work</span>
                <p class="text-sm text-[#A1A1AA] leading-relaxed">
                  {focusDesc}
                </p>
              </div>
            </section>
          );

        case "projects":
          return (
            <section id="work" class="flex flex-col gap-8 border-t border-[rgba(255,255,255,0.08)] pt-12">
              <div class="flex justify-between items-baseline">
                <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">Selected Work</h2>
                <a href="/work" class="text-xs text-[#2563EB] hover:underline font-mono">View All Projects &rarr;</a>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {featuredProjects.slice(0, widget.limit || 4).map((project) => (
                  <article class="p-6 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-3">
                    <div class="flex justify-between items-baseline">
                      <h3 class="text-base font-medium text-[#FAFAFA]">
                        <a href={project.data.caseStudy || `/work/${project.slug}`} class="hover:text-[#2563EB] transition-colors">
                          {project.data.title}
                        </a>
                      </h3>
                      <span class="text-xs text-[#71717A] font-mono">{project.data.year}</span>
                    </div>
                    <p class="text-xs text-[#A1A1AA] leading-relaxed line-clamp-2">
                      {project.data.description}
                    </p>
                  </article>
                ))}
              </div>
            </section>
          );

        case "writing":
          return (
            <section id="writing" class="flex flex-col gap-8 border-t border-[rgba(255,255,255,0.08)] pt-12">
              <div class="flex justify-between items-baseline">
                <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">Writing</h2>
                <a href="/writing" class="text-xs text-[#2563EB] hover:underline font-medium">Browse articles &rarr;</a>
              </div>
              <div class="flex flex-col gap-6">
                {latestArticles.slice(0, widget.limit || 3).map((post) => (
                  <a href={`/writing/${post.slug}`} class="group p-5 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-2 hover:border-[#2563EB]/40 transition-colors">
                    <div class="flex justify-between items-baseline gap-2">
                      <h3 class="text-base font-medium text-[#FAFAFA] group-hover:text-[#2563EB] transition-colors">
                        {post.data.title}
                      </h3>
                      <span class="text-xs text-[#71717A] font-mono">
                        {new Date(post.data.published).toLocaleDateString("en-US", { year: "numeric", month: "short" })}
                      </span>
                    </div>
                    <p class="text-xs text-[#A1A1AA] leading-relaxed line-clamp-2">
                      {post.data.description}
                    </p>
                  </a>
                ))}
              </div>
            </section>
          );

        case "reading":
          return (
            <section id="reading" class="flex flex-col gap-6 border-t border-[rgba(255,255,255,0.08)] pt-12">
              <div class="flex justify-between items-baseline">
                <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">Latest Notes</h2>
                <a href="/notes" class="text-xs text-[#2563EB] hover:underline font-medium">View all notes &rarr;</a>
              </div>
              <div class="flex flex-col gap-4">
                {latestNotes.slice(0, widget.limit || 3).map(note => (
                  <a href={`/notes/${note.slug}`} class="flex justify-between items-baseline border-b border-white/5 pb-2 hover:text-[#2563EB] transition-colors">
                    <span class="text-sm font-medium text-[#FAFAFA]">{note.data.title}</span>
                    <span class="text-xs text-[#71717A] font-mono">{note.data.topic}</span>
                  </a>
                ))}
              </div>
            </section>
          );

        case "newsletter":
          return (
            <div class="border-t border-[rgba(255,255,255,0.08)] pt-8">
              <Newsletter />
            </div>
          );

        default:
          return null;
      }
    })}

  </main>

  <Footer />
</Layout>
