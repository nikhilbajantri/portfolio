---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

const books = [
  {
    title: "Designing Data-Intensive Applications",
    author: "Martin Kleppmann",
    progress: "18%",
    started: "1 week ago",
    idea: "Reliability under load requires deliberate architectural patterns rather than just scaling machines.",
    notes: "Studying serialization protocols, storage engines, and log-structured merge trees.",
    target: "Engineers building backend databases or high-throughput real-time APIs."
  },
  {
    title: "The Pragmatic Programmer",
    author: "Andrew Hunt & David Thomas",
    progress: "Completed",
    started: "Finished June 2026",
    idea: "Great software starts with personal habits. Care about your craft and always test assumptions.",
    notes: "Learned the value of orthogonality, tracer bullets, and keeping configurations isolated.",
    target: "Developers wanting to establish robust workflow systems and coding fundamentals."
  }
];

const recommendations = {
  books: [
    { title: "Deep Work", author: "Cal Newport" },
    { title: "Steve Jobs", author: "Walter Isaacson" },
    { title: "Zero to One", author: "Peter Thiel" }
  ],
  articles: [
    { title: "Reflections on Trusting Trust", author: "Ken Thompson" },
    { title: "Hackers & Painters", author: "Paul Graham" }
  ],
  tools: [
    { title: "Git", desc: "Decentralized version control" },
    { title: "Cursor / Neovim", desc: "Text editing environments" }
  ],
  podcasts: [
    { title: "Lex Fridman Podcast", host: "Lex Fridman" }
  ],
  people: [
    { name: "Derek Sivers", url: "https://sivers.org/" },
    { name: "Paul Graham", url: "https://paulgraham.com/" }
  ]
};
---

<Layout title="Reading">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[960px] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6 max-w-[68ch]">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Reading
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        Books shape my engineering decisions and technical philosophy.
        This is a record of ideas, notes, and recommendations that have stayed with me.
      </p>
    </header>

    <!-- Currently Reading & Detailed Logs -->
    <section class="flex flex-col gap-12">
      {books.map((book) => (
        <article class="flex flex-col gap-6 border-b border-[rgba(255,255,255,0.06)] pb-12 last:border-0 last:pb-0">
          
          <div class="flex flex-col gap-1.5">
            <div class="flex justify-between items-start gap-4">
              <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">{book.title}</h2>
              <span class="text-xs px-2.5 py-0.5 bg-[#2563EB]/10 text-[#2563EB] rounded-[999px] font-mono whitespace-nowrap">{book.progress}</span>
            </div>
            <p class="text-xs text-[#71717A] font-mono">by {book.author} · Started {book.started}</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-sm text-[#A1A1AA] leading-relaxed pt-2">
            
            <div class="flex flex-col gap-1.5">
              <span class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">Idea I Learned</span>
              <p>{book.idea}</p>
            </div>

            <div class="flex flex-col gap-1.5">
              <span class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">My Notes</span>
              <p>{book.notes}</p>
            </div>

            <div class="flex flex-col gap-1.5">
              <span class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">Who Should Read It</span>
              <p>{book.target}</p>
            </div>

          </div>

        </article>
      ))}
    </section>

    <!-- Recommendations Directory (Worth Your Time) -->
    <section class="flex flex-col gap-8 border-t border-[rgba(255,255,255,0.08)] pt-12">
      <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">Worth Your Time</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
        
        <!-- Books -->
        <div class="flex flex-col gap-3">
          <h3 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">Books</h3>
          <ul class="flex flex-col gap-2 text-sm text-[#A1A1AA]">
            {recommendations.books.map((b) => (
              <li>
                <span class="text-[#FAFAFA] font-medium">{b.title}</span>
                <span class="text-[#71717A] text-xs block">by {b.author}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Articles -->
        <div class="flex flex-col gap-3">
          <h3 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">Articles</h3>
          <ul class="flex flex-col gap-2 text-sm text-[#A1A1AA]">
            {recommendations.articles.map((art) => (
              <li>
                <span class="text-[#FAFAFA] font-medium">{art.title}</span>
                <span class="text-[#71717A] text-xs block">by {art.author}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Tools -->
        <div class="flex flex-col gap-3">
          <h3 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">Tools</h3>
          <ul class="flex flex-col gap-2 text-sm text-[#A1A1AA]">
            {recommendations.tools.map((tool) => (
              <li>
                <span class="text-[#FAFAFA] font-medium">{tool.title}</span>
                <span class="text-[#71717A] text-xs block">{tool.desc}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>
