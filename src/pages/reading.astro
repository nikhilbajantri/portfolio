---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { getBooks } from "../lib/content";

const books = await getBooks();

const recommendations = {
  books: [
    { title: "Deep Work", author: "Cal Newport" },
    { title: "Steve Jobs", author: "Walter Isaacson" },
    { title: "Zero to One", author: "Peter Thiel" }
  ],
  articles: [
    { title: "Reflections on Trusting Trust", author: "Ken Thompson" },
    { title: "Hackers & Painters", author: "Paul Graham" }
  ],
  tools: [
    { title: "Git", desc: "Decentralized version control" },
    { title: "Cursor / Neovim", desc: "Text editing environments" }
  ]
};
---

<Layout title="Reading">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[68ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-4">
      <h1 class="text-4xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Reading
      </h1>
      <p class="text-base text-[#A1A1AA] leading-relaxed">
        Logs, annotations, and key takeaways from books I study to understand systems and software design.
      </p>
    </header>

    <!-- Books list -->
    <div class="flex flex-col gap-12 border-b border-[rgba(255,255,255,0.06)] pb-12">
      {books.map((book) => (
        <section class="flex flex-col gap-4 border border-[rgba(255,255,255,0.06)] p-6 bg-[#111113]/50 rounded-xl">
          <div class="flex justify-between items-baseline gap-2">
            <h2 class="text-lg font-medium text-[#FAFAFA]">
              <a href={`/books/${book.slug}`} class="hover:underline">{book.data.title}</a>
            </h2>
            <span class="text-xs text-[#71717A] font-mono">{book.data.status}</span>
          </div>
          <span class="text-xs text-[#A1A1AA] font-mono">by {book.data.author} · {book.data.category}</span>
          {book.data.favoriteQuote && (
            <p class="text-xs text-[#71717A] italic">"{book.data.favoriteQuote}"</p>
          )}
          {book.data.ideas && book.data.ideas.length > 0 && (
            <div class="mt-2 flex flex-col gap-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-[#71717A] font-semibold">Key Ideas</span>
              <ul class="list-disc pl-4 text-xs text-[#A1A1AA] flex flex-col gap-1">
                {book.data.ideas.map(idea => (
                  <li>{idea}</li>
                ))}
              </ul>
            </div>
          )}
        </section>
      ))}
    </div>

    <!-- Recommendations Grid -->
    <section class="flex flex-col gap-6">
      <h2 class="text-xs font-mono text-[#71717A] uppercase tracking-wider font-semibold">Curated References</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-sm">
        <div>
          <span class="block text-xs font-mono text-white mb-2 uppercase tracking-wide">Books</span>
          <ul class="flex flex-col gap-1 text-[#A1A1AA]">
            {recommendations.books.map(b => (
              <li>{b.title} <span class="text-[#71717A] text-xs">by {b.author}</span></li>
            ))}
          </ul>
        </div>
        <div>
          <span class="block text-xs font-mono text-white mb-2 uppercase tracking-wide">Articles</span>
          <ul class="flex flex-col gap-1 text-[#A1A1AA]">
            {recommendations.articles.map(a => (
              <li>{a.title} <span class="text-[#71717A] text-xs">by {a.author}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
