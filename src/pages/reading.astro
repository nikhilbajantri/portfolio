---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

// Currently reading details
const currentlyReading = [
  {
    title: "The Pragmatic Programmer",
    author: "Andrew Hunt & David Thomas",
    progress: "42%",
    started: "3 days ago",
    takeaway: "Care about your craft."
  },
  {
    title: "Design Patterns",
    author: "Erich Gamma, Richard Helm, Ralph Johnson, John Vlissides",
    progress: "15%",
    started: "2 weeks ago",
    takeaway: "Favor object composition over class inheritance."
  }
];

// Ideas That Stayed With Me
const ideasWorthKeeping = [
  {
    title: "Deep Work",
    author: "Cal Newport",
    takeaway: "Attention is a competitive advantage in a distracted world."
  },
  {
    title: "The Pragmatic Programmer",
    author: "Andrew Hunt & David Thomas",
    takeaway: "Great software starts with great habits and continuous refinement."
  },
  {
    title: "Principles",
    author: "Ray Dalio",
    takeaway: "Systematize decision-making to operate without emotional bias."
  }
];

// Book Notes (synthesized write-ups)
const bookNotes = [
  {
    title: "Synthesizing Deep Work",
    date: "July 2026",
    description: "Takeaways on establishing focus loops and structural attention filters.",
    slug: "/writing/why-i-started-writing"
  }
];

// Recommendations
const recommendations = {
  books: [
    { title: "Deep Work", author: "Cal Newport" },
    { title: "Steve Jobs", author: "Walter Isaacson" },
    { title: "Zero to One", author: "Peter Thiel" }
  ],
  articles: [
    { title: "Reflections on Trusting Trust", author: "Ken Thompson" },
    { title: "Hackers & Painters", author: "Paul Graham" }
  ],
  tools: [
    { title: "Git", desc: "Version control" },
    { title: "Cursor / Neovim", desc: "Text editing environments" }
  ],
  podcasts: [
    { title: "Lex Fridman Podcast", host: "Lex Fridman" }
  ],
  people: [
    { name: "Derek Sivers", url: "https://sivers.org/" },
    { name: "Paul Graham", url: "https://paulgraham.com/" }
  ]
};
---

<Layout title="Reading">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[960px] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6 max-w-[68ch]">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Reading
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        Books have shaped my thinking more than any framework ever has.
        I read to strengthen my understanding of engineering, systems, psychology, and decision making.
      </p>
    </header>

    <!-- 1. Currently Reading -->
    <section class="flex flex-col gap-6">
      <h2 class="text-xs font-medium text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        Currently Reading
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {currentlyReading.map((book) => (
          <div class="p-6 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-3">
            <div class="flex justify-between items-start gap-4">
              <div>
                <h3 class="text-base font-medium text-[#FAFAFA]">{book.title}</h3>
                <p class="text-xs text-[#71717A] font-mono">by {book.author}</p>
              </div>
              <span class="text-xs px-2 py-0.5 bg-[#2563EB]/10 text-[#2563EB] rounded-[999px] font-mono">{book.progress}</span>
            </div>
            <div class="text-xs text-[#71717A] font-mono">
              Started {book.started}
            </div>
            <div class="mt-2 border-t border-[rgba(255,255,255,0.04)] pt-3 flex flex-col gap-1">
              <span class="text-[#71717A] block font-mono text-[9px] uppercase tracking-wider">One idea that stood out</span>
              <span class="text-[#FAFAFA] italic text-xs">"{book.takeaway}"</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 2. Ideas Worth Keeping -->
    <section class="flex flex-col gap-6">
      <h2 class="text-xs font-medium text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        Ideas Worth Keeping
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {ideasWorthKeeping.map((idea) => (
          <div class="p-6 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-2">
            <h3 class="text-base font-medium text-[#FAFAFA]">{idea.title}</h3>
            <p class="text-xs text-[#71717A] font-mono">by {idea.author}</p>
            <p class="text-sm text-[#A1A1AA] leading-relaxed mt-2">
              {idea.takeaway}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- 3. Book Notes -->
    <section class="flex flex-col gap-6">
      <h2 class="text-xs font-medium text-[#71717A] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        Book Notes
      </h2>
      <div class="flex flex-col gap-6">
        {bookNotes.map((note) => (
          <a href={note.slug} class="group flex flex-col gap-2">
            <div class="flex justify-between items-baseline gap-4">
              <h3 class="text-base font-medium text-[#FAFAFA] group-hover:text-[#2563EB] transition-colors duration-180">
                {note.title}
              </h3>
              <span class="text-xs text-[#71717A] font-mono">{note.date}</span>
            </div>
            <p class="text-sm text-[#A1A1AA] leading-relaxed max-w-[68ch]">
              {note.description}
            </p>
          </a>
        ))}
      </div>
    </section>

    <!-- 4. Recommendations (Worth Your Time) -->
    <section class="flex flex-col gap-8 border-t border-[rgba(255,255,255,0.08)] pt-12">
      <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">Worth Your Time</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
        
        <!-- Books -->
        <div class="flex flex-col gap-3">
          <h3 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">Books</h3>
          <ul class="flex flex-col gap-2 text-sm text-[#A1A1AA]">
            {recommendations.books.map((book) => (
              <li>
                <span class="text-[#FAFAFA] font-medium">{book.title}</span>
                <span class="text-[#71717A] text-xs block">by {book.author}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Articles -->
        <div class="flex flex-col gap-3">
          <h3 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">Articles</h3>
          <ul class="flex flex-col gap-2 text-sm text-[#A1A1AA]">
            {recommendations.articles.map((art) => (
              <li>
                <span class="text-[#FAFAFA] font-medium">{art.title}</span>
                <span class="text-[#71717A] text-xs block">by {art.author}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Tools -->
        <div class="flex flex-col gap-3">
          <h3 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">Tools</h3>
          <ul class="flex flex-col gap-2 text-sm text-[#A1A1AA]">
            {recommendations.tools.map((tool) => (
              <li>
                <span class="text-[#FAFAFA] font-medium">{tool.title}</span>
                <span class="text-[#71717A] text-xs block">{tool.desc}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>
