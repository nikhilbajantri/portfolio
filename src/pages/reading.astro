---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

// Books Worth Re-reading & Ideas That Stayed With Me
const booksWorthReReading = [
  {
    title: "Deep Work",
    author: "Cal Newport",
    takeaway: "Attention is a competitive advantage in a distracted world."
  },
  {
    title: "The Pragmatic Programmer",
    author: "Andrew Hunt & David Thomas",
    takeaway: "Great software starts with great habits and continuous refinement."
  },
  {
    title: "Atomic Habits",
    author: "James Clear",
    takeaway: "Small consistent habits compound into remarkable long-term results."
  },
  {
    title: "Principles",
    author: "Ray Dalio",
    takeaway: "Systematize decision-making to operate without emotional bias."
  }
];

// Currently reading & List
const currentlyReading = [
  { title: "Design Patterns", author: "Erich Gamma, Richard Helm, Ralph Johnson, John Vlissides" }
];

const recentlyFinished = [
  { title: "The Psychology of Money", author: "Morgan Housel" },
  { title: "Steve Jobs", author: "Walter Isaacson" },
  { title: "Zero to One", author: "Peter Thiel" }
];

// Worth Your Time Recommendations
const recommendations = {
  books: [
    { title: "Deep Work", author: "Cal Newport" },
    { title: "Steve Jobs", author: "Walter Isaacson" },
    { title: "The Pragmatic Programmer", author: "Andrew Hunt & David Thomas" }
  ],
  articles: [
    { title: "Reflections on Trusting Trust", author: "Ken Thompson" },
    { title: "Hackers & Painters", author: "Paul Graham" }
  ],
  tools: [
    { title: "Git", desc: "Version control" },
    { title: "Cursor / Neovim", desc: "Focused text editing" },
    { title: "Brave Browser", desc: "Default client browsing" }
  ],
  podcasts: [
    { title: "Lex Fridman Podcast", host: "Lex Fridman" }
  ],
  people: [
    { name: "Derek Sivers", url: "https://sivers.org/" },
    { name: "Paul Graham", url: "https://paulgraham.com/" }
  ]
};
---

<Layout title="Reading">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[960px] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-16 font-sans">
    
    <!-- Header -->
    <header class="flex flex-col gap-6 max-w-[72ch]">
      <h1 class="text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-none">
        Reading
      </h1>
      <p class="text-lg text-[#A1A1AA] leading-relaxed">
        Books have shaped my thinking more than any framework ever has.
        I read to strengthen my understanding of engineering, cybersecurity, psychology, systems, and entrepreneurship.
      </p>
    </header>

    <!-- Ideas That Stayed With Me -->
    <section class="flex flex-col gap-6">
      <h2 class="text-xs font-medium text-[#FAFAFA] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
        Ideas That Stayed With Me
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {booksWorthReReading.map((book) => (
          <div class="p-6 bg-[#111113] border border-[rgba(255,255,255,0.08)] rounded-[16px] flex flex-col gap-2">
            <h3 class="text-base font-medium text-[#FAFAFA]">{book.title}</h3>
            <p class="text-xs text-[#71717A] font-mono">by {book.author}</p>
            <p class="text-sm text-[#A1A1AA] leading-relaxed mt-2">
              {book.takeaway}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- Currently & Recently Finished -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      
      <!-- Currently Reading -->
      <section class="flex flex-col gap-4">
        <h2 class="text-xs font-medium text-[#FAFAFA] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
          Currently Reading
        </h2>
        <ul class="flex flex-col gap-3">
          {currentlyReading.map((book) => (
            <li class="flex flex-col">
              <span class="text-sm font-medium text-[#FAFAFA]">{book.title}</span>
              <span class="text-xs text-[#71717A]">{book.author}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Recently Finished -->
      <section class="flex flex-col gap-4">
        <h2 class="text-xs font-medium text-[#FAFAFA] uppercase tracking-wider border-b border-[rgba(255,255,255,0.08)] pb-2">
          Recently Finished
        </h2>
        <ul class="flex flex-col gap-3">
          {recentlyFinished.map((book) => (
            <li class="flex flex-col">
              <span class="text-sm font-medium text-[#FAFAFA]">{book.title}</span>
              <span class="text-xs text-[#71717A]">{book.author}</span>
            </li>
          ))}
        </ul>
      </section>

    </div>

    <!-- Worth Your Time Recommendations -->
    <section class="flex flex-col gap-8 border-t border-[rgba(255,255,255,0.08)] pt-12">
      <h2 class="text-2xl font-display font-medium text-[#FAFAFA] tracking-tight">Worth Your Time</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
        
        <!-- Recommended Books -->
        <div class="flex flex-col gap-3">
          <h3 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">Books</h3>
          <ul class="flex flex-col gap-2 text-sm text-[#A1A1AA]">
            {recommendations.books.map((book) => (
              <li>
                <span class="text-[#FAFAFA] font-medium">{book.title}</span>
                <span class="text-[#71717A] text-xs block">by {book.author}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Recommended Articles -->
        <div class="flex flex-col gap-3">
          <h3 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">Articles</h3>
          <ul class="flex flex-col gap-2 text-sm text-[#A1A1AA]">
            {recommendations.articles.map((art) => (
              <li>
                <span class="text-[#FAFAFA] font-medium">{art.title}</span>
                <span class="text-[#71717A] text-xs block">by {art.author}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Recommended Tools -->
        <div class="flex flex-col gap-3">
          <h3 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider">Tools</h3>
          <ul class="flex flex-col gap-2 text-sm text-[#A1A1AA]">
            {recommendations.tools.map((tool) => (
              <li>
                <span class="text-[#FAFAFA] font-medium">{tool.title}</span>
                <span class="text-[#71717A] text-xs block">{tool.desc}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>
