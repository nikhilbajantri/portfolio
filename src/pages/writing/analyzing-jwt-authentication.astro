---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Analyzing JWT Authentication Mechanisms">
  <Navigation />

  <main id="main-content" class="flex-1 max-w-[68ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-12 font-sans">
    
    <!-- Article Header -->
    <header class="flex flex-col gap-4">
      <div class="flex gap-2 text-xs text-[#71717A] font-mono">
        <span>Cybersecurity</span>
        <span>·</span>
        <span>May 2026</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-tight">
        Analyzing JWT Authentication Mechanisms
      </h1>
      <p class="text-sm text-[#A1A1AA] italic">
        "Understand signature verifications and cookie storage scopes."
      </p>
    </header>

    <!-- Article Content -->
    <div class="flex flex-col gap-8 text-[#FAFAFA] text-base leading-[1.7] tracking-tight font-normal">
      <p>
        JSON Web Tokens (JWT) are commonly used for stateless authorization.
        However, they are frequently implemented with critical security vulnerabilities.
        For example, storing tokens in browser local storage exposes them to Cross-Site Scripting (XSS) attacks.
      </p>
      
      <p>
        To mitigate this risk, tokens should be stored in HTTP-only, secure cookies with the SameSite flag enabled.
        This design prevents client-side scripts from reading the authorization data.
        Additionally, the API backend must enforce signature validation checks and reject tokens with the 'none' algorithm.
      </p>

      <p>
        Stateless authentication is a convenient pattern, but correctness requires rigorous protocol alignment.
        We must always verify signature scopes and isolate token access parameters.
      </p>
    </div>

    <!-- Interactive Section: JWT Decoder -->
    <section class="border border-[rgba(255,255,255,0.08)] bg-[#111113] p-6 rounded-xl flex flex-col gap-4">
      <div>
        <h3 class="text-xs font-semibold text-[#FAFAFA] uppercase tracking-wider mb-1">Local JWT Decoder</h3>
        <p class="text-xs text-[#71717A] leading-relaxed">
          Paste a token to inspect its header and payload contents. All decoding is processed locally in your browser.
        </p>
      </div>

      <textarea
        id="jwt-input"
        placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c"
        rows="4"
        class="w-full bg-[#09090B] border border-[rgba(255,255,255,0.08)] rounded-lg p-3 text-xs font-mono text-[#FAFAFA] placeholder-[#71717A] outline-none focus:border-[#2563EB]/40 transition-colors"
      ></textarea>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs">
        
        <!-- Header -->
        <div class="flex flex-col gap-1.5">
          <span class="text-[#71717A] font-mono tracking-tight font-medium">Header</span>
          <pre id="jwt-header-out" class="p-3 bg-[#09090B] border border-[rgba(255,255,255,0.04)] rounded-lg text-[11px] font-mono text-[#FAFAFA] overflow-x-auto min-h-[80px]">{"Waiting..."}</pre>
        </div>

        <!-- Payload -->
        <div class="flex flex-col gap-1.5">
          <span class="text-[#71717A] font-mono tracking-tight font-medium">Payload</span>
          <pre id="jwt-payload-out" class="p-3 bg-[#09090B] border border-[rgba(255,255,255,0.04)] rounded-lg text-[11px] font-mono text-[#FAFAFA] overflow-x-auto min-h-[80px]">{"Waiting..."}</pre>
        </div>

      </div>
    </section>

    <!-- Article Footer -->
    <footer class="flex flex-col gap-8 border-t border-[rgba(255,255,255,0.06)] pt-12 mt-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 text-sm">
        <div class="flex flex-col gap-3">
          <h4 class="text-xs text-[#71717A] uppercase tracking-wider font-medium font-mono font-semibold">Further Reading</h4>
          <ul class="flex flex-col gap-2">
            <li>
              <a href="/lab/jwt-visualizer" class="text-[#2563EB] hover:underline font-medium">
                Lab Experiment: Interactive JWT Visualizer →
              </a>
            </li>
            <li>
              <a href="/writing/my-cybersecurity-roadmap" class="text-[#2563EB] hover:underline">
                My Cybersecurity Roadmap
              </a>
            </li>
          </ul>
        </div>
      </div>
    </footer>

  </main>

  <Footer />

  <!-- Local decoder logic -->
  <script is:inline>
    const jwtInput = document.getElementById('jwt-input');
    const headerOut = document.getElementById('jwt-header-out');
    const payloadOut = document.getElementById('jwt-payload-out');

    function urlBase64Decode(str) {
      try {
        let output = str.replace(/-/g, "+").replace(/_/g, "/");
        switch (output.length % 4) {
          case 0: break;
          case 2: output += "=="; break;
          case 3: output += "="; break;
          default: throw "Illegal base64url string!";
        }
        return decodeURIComponent(atob(output).split("").map(c => "%" + ("00" + c.charCodeAt(0).toString(16)).slice(-2)).join(""));
      } catch (err) {
        return null;
      }
    }

    function decodeJwt() {
      const token = jwtInput.value.trim();
      if (!token) {
        headerOut.textContent = "Waiting...";
        payloadOut.textContent = "Waiting...";
        return;
      }

      const parts = token.split('.');
      if (parts.length !== 3) {
        headerOut.textContent = "Error: Invalid JWT structure (must contain 3 parts separated by dots).";
        payloadOut.textContent = "Error: Invalid JWT structure.";
        return;
      }

      const decodedHeader = urlBase64Decode(parts[0]);
      const decodedPayload = urlBase64Decode(parts[1]);

      if (decodedHeader) {
        try {
          const parsed = JSON.parse(decodedHeader);
          headerOut.textContent = JSON.stringify(parsed, null, 2);
        } catch (e) {
          headerOut.textContent = decodedHeader;
        }
      } else {
        headerOut.textContent = "Error decoding base64url header.";
      }

      if (decodedPayload) {
        try {
          const parsed = JSON.parse(decodedPayload);
          payloadOut.textContent = JSON.stringify(parsed, null, 2);
        } catch (e) {
          payloadOut.textContent = decodedPayload;
        }
      } else {
        payloadOut.textContent = "Error decoding base64url payload.";
      }
    }

    jwtInput.addEventListener('input', decodeJwt);
    decodeJwt(); // Initialize if default value exists
  </script>
</Layout>
