---
import CollectionLayout from "./CollectionLayout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description: string;
  };
}

const { frontmatter } = Astro.props;
---

<CollectionLayout title={frontmatter.title} description={frontmatter.description}>
  <main id="main-content" class="flex-1 max-w-[68ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-12 font-sans">
    
    <!-- Page Header -->
    <header class="flex flex-col gap-4">
      <h1 class="text-4xl sm:text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-tight">
        {frontmatter.title}
      </h1>
      <p class="text-base text-[#A1A1AA] leading-relaxed">
        {frontmatter.description}
      </p>
    </header>

    <!-- Page Content Slot -->
    <article class="prose prose-invert max-w-none text-[#FAFAFA] text-base leading-[1.7] tracking-tight font-normal flex flex-col gap-6">
      <slot />
    </article>

  </main>
</CollectionLayout>
