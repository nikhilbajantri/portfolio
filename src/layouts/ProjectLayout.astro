---
import CollectionLayout from "./CollectionLayout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description: string;
    status: string;
    visibility: string;
    year: number;
    role: string;
    repository?: string;
    demo?: string;
    languages?: string[];
    frameworks?: string[];
    database?: string[];
    infrastructure?: string[];
    services?: string[];
    architecture?: string[];
  };
}

const { frontmatter } = Astro.props;

// Status color helper mapping
const statusColors = {
  "Planning": "text-yellow-400 bg-yellow-400/10 border-yellow-400/20",
  "In Development": "text-blue-400 bg-blue-400/10 border-blue-400/20",
  "Production": "text-emerald-400 bg-emerald-400/10 border-emerald-400/20",
  "Maintenance": "text-zinc-400 bg-zinc-400/10 border-zinc-400/20",
  "Archived": "text-[#71717A] bg-white/5 border-white/10"
};

const badgeClass = statusColors[frontmatter.status] || statusColors["Production"];
---

<CollectionLayout title={frontmatter.title} description={frontmatter.description}>
  <main id="main-content" class="flex-1 max-w-[68ch] mx-auto px-6 py-16 sm:py-24 flex flex-col gap-12 font-sans">
    
    <!-- Project Header -->
    <header class="flex flex-col gap-4">
      <div class="flex items-center gap-2">
        <span class={`px-2 py-0.5 rounded text-[10px] font-mono border uppercase tracking-wider ${badgeClass}`}>
          ● {frontmatter.status}
        </span>
        <span class="text-xs text-[#71717A] font-mono">{frontmatter.year}</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-display font-medium text-[#FAFAFA] tracking-tight leading-tight">
        {frontmatter.title}
      </h1>
      <p class="text-base text-[#A1A1AA] leading-relaxed">
        {frontmatter.description}
      </p>
    </header>

    <!-- Meta specs panel -->
    <div class="grid grid-cols-2 gap-x-8 gap-y-4 border-y border-[rgba(255,255,255,0.06)] py-6 font-mono text-xs text-[#71717A]">
      <div>
        <span class="block text-white font-semibold uppercase tracking-wider mb-1">Role</span>
        <span>{frontmatter.role}</span>
      </div>
      {frontmatter.architecture && frontmatter.architecture.length > 0 && (
        <div>
          <span class="block text-white font-semibold uppercase tracking-wider mb-1">Architecture</span>
          <span>{frontmatter.architecture.join(", ")}</span>
        </div>
      )}
      <div>
        <span class="block text-white font-semibold uppercase tracking-wider mb-1">Stack</span>
        <div class="flex flex-col gap-1 text-[#A1A1AA] mt-1">
          {frontmatter.languages && frontmatter.languages.length > 0 && (
            <span>Languages: {frontmatter.languages.join(", ")}</span>
          )}
          {frontmatter.frameworks && frontmatter.frameworks.length > 0 && (
            <span>Frameworks: {frontmatter.frameworks.join(", ")}</span>
          )}
          {frontmatter.database && frontmatter.database.length > 0 && (
            <span>Database: {frontmatter.database.join(", ")}</span>
          )}
        </div>
      </div>
      <div class="flex flex-col gap-2">
        <span class="block text-white font-semibold uppercase tracking-wider">Links</span>
        <div class="flex gap-4 text-[#2563EB]">
          {frontmatter.demo && (
            <a href={frontmatter.demo} target="_blank" rel="noopener noreferrer" class="hover:underline">
              Live Demo
            </a>
          )}
          {frontmatter.repository && (
            <a href={frontmatter.repository} target="_blank" rel="noopener noreferrer" class="hover:underline">
              Repository
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Case Study Body -->
    <article class="prose prose-invert max-w-none text-[#FAFAFA] text-base leading-[1.7] tracking-tight font-normal flex flex-col gap-6">
      <slot />
    </article>

    <!-- Comments (Giscus) -->
    <div class="border-t border-[rgba(255,255,255,0.06)] pt-12 mt-8">
      <h3 class="text-lg font-medium text-white mb-6 font-display">Discussion</h3>
      <script is:inline src="https://giscus.app/client.js"
              data-repo="nikhilbajantri/portfolio"
              data-repo-id="R_kgDOL82fBA"
              data-category="Announcements"
              data-category-id="DIC_kwDOL82fBM4CdM-3"
              data-mapping="pathname"
              data-strict="0"
              data-reactions-enabled="1"
              data-emit-metadata="0"
              data-input-position="top"
              data-theme="dark"
              data-lang="en"
              crossorigin="anonymous"
              async>
      </script>
    </div>

  </main>
</CollectionLayout>
