---
import Layout from "./Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: string;
  keywords?: string;
}

const { title, description, image, canonical, type, keywords } = Astro.props;
---

<Layout 
  title={title} 
  description={description} 
  image={image} 
  canonical={canonical} 
  type={type} 
  keywords={keywords}
>
  <Navigation />
  
  <slot />
  
  <Footer />
</Layout>
