---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: string;
  keywords?: string;
}

const {
  title,
  description = "A place to build, learn, write, and think in public. Personal website of Nikhil Bajantri, documenting software engineering, systems, cybersecurity, and books.",
  image = "/profile-image.jpg",
  canonical = Astro.url.href,
  type = "website",
  keywords = "Nikhil Bajantri, Software Engineer, Writer, Systems, Cybersecurity, Distributed Systems, Books, nikhilbajantri.dev",
} = Astro.props;

const siteName = "nikhilbajantri.dev";
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth bg-[#09090B] text-[#FAFAFA]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#2563EB" />
    <meta name="robots" content="index, follow" />

    <!-- Google Site Verification -->
    <meta name="google-site-verification" content="6F8WceAuAicNFX86Tsc_oMI-CKOgDdIb3x-Bm7Xkb1Y" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-59S5B1XTM4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-59S5B1XTM4');
    </script>

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Nikhil Bajantri" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title={`RSS Feed for ${siteName}`} href="/rss.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />
    <meta property="twitter:creator" content="@nikkkkhil_2604" />

    <!-- Favicon and Icons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts: Geist, Inter, JetBrains Mono -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/font/sans.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/font/mono.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Preload critical assets -->
    <link rel="preload" href="/profile-image.jpg" as="image" />

    <!-- Font Awesome (for minimal icon references if needed, but prefer text/SVG) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  </head>
  <body class="bg-[#09090B] text-[#FAFAFA] antialiased selection:bg-[#2563EB]/25 selection:text-white min-h-screen flex flex-col font-sans">
    
    <!-- Skip to content for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-[#2563EB] focus:text-white focus:rounded-lg focus:outline-none">
      Skip to main content
    </a>

    <!-- Subtle noise texture overlay for analog feel -->
    <div
      class="fixed inset-0 pointer-events-none z-50 opacity-[0.015]"
      style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 256 256%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%223%22 stitchTiles=%22stitch%22/></filter><rect width=%22256%22 height=%22256%22 filter=%22url(%23n)%22 opacity=%220.5%22/></svg>'); background-size: 128px;"
    ></div>

    <slot />

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- COMMAND MENU (⌘K SEARCH)                               -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <div
      id="search-modal"
      class="fixed inset-0 z-50 bg-[#09090B]/80 backdrop-blur-sm flex items-start justify-center pt-[15vh] px-4 opacity-0 pointer-events-none transition-all duration-180"
      role="dialog"
      aria-modal="true"
    >
      <div class="bg-[#111113] border border-[rgba(255,255,255,0.08)] w-full max-w-xl rounded-xl shadow-2xl overflow-hidden flex flex-col">
        <!-- Search Input -->
        <div class="flex items-center px-4 py-3 border-b border-[rgba(255,255,255,0.08)]">
          <svg class="w-5 h-5 text-[#71717A] mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            id="search-input"
            type="text"
            placeholder="Search articles, case studies, library..."
            class="bg-transparent text-sm text-[#FAFAFA] placeholder-[#71717A] w-full outline-none"
            autocomplete="off"
          />
          <button id="close-search-button" class="text-xs text-[#71717A] hover:text-[#FAFAFA] transition-colors font-mono">
            ESC
          </button>
        </div>

        <!-- Search Results List -->
        <div id="search-results" class="max-h-[350px] overflow-y-auto p-2 flex flex-col gap-1">
          <!-- Populated by JS -->
        </div>

        <!-- Footer Help -->
        <div class="px-4 py-2 border-t border-[rgba(255,255,255,0.04)] bg-[#09090B] flex items-center justify-between text-[11px] text-[#71717A]">
          <div>
            <span>↑↓ to navigate</span>
            <span class="mx-1.5">·</span>
            <span>Enter to select</span>
          </div>
          <div>
            <span>⌘K to close</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Client-side Search Logic -->
    <script is:inline>
      const searchModal = document.getElementById('search-modal');
      const searchInput = document.getElementById('search-input');
      const searchResults = document.getElementById('search-results');
      const closeSearchButton = document.getElementById('close-search-button');

      let isOpen = false;
      let activeIndex = -1;
      let filteredItems = [];

      // Search Database
      const searchData = [
        { title: "Home", category: "Page", url: "/", desc: "Homepage of nikhilbajantri.dev." },
        { title: "Writing", category: "Page", url: "/writing", desc: "Technical articles, deep dives, and long-form essays." },
        { title: "Work", category: "Page", url: "/work", desc: "Detailed software engineering case studies." },
        { title: "Reading", category: "Page", url: "/reading", desc: "Nikhil's bookshelf, re-reading lists, and ideas." },
        { title: "About", category: "Page", url: "/about", desc: "Operating manual, motives, and philosophies." },
        { title: "Now", category: "Page", url: "/now", desc: "Current focus, priorities, and status updates." },
        { title: "Uses", category: "Page", url: "/uses", desc: "Physical setup, developer workflow, and security tools." },
        { title: "Principles", category: "Page", url: "/principles", desc: "Core philosophies that guide decision making." },
        { title: "Thinking", category: "Page", url: "/thinking", desc: "Curated active exploration questions." },
        { title: "Favorites", category: "Page", url: "/favorites", desc: "Influential books, articles, tools, and repositories." },
        { title: "Notes", category: "Page", url: "/notes", desc: "Second brain directory of single-idea logs." },
        { title: "Colophon", category: "Page", url: "/colophon", desc: "Technical details, framework, and fonts." },
        { title: "Résumé", category: "Page", url: "/about/resume", desc: "Skimmable resume and professional summary." },
        
        { title: "Why I Started Writing", category: "Essay", url: "/writing/why-i-started-writing", desc: "How writing compounds software understanding." },
        { title: "Why I Built This Website", category: "Essay", url: "/writing/why-i-built-this-website", desc: "A defense of personal websites and local-first layouts." },
        { title: "The Kind of Engineer I Want to Become", category: "Essay", url: "/writing/the-kind-of-engineer-i-want-to-become", desc: "Reflections on craftsman philosophy." },
        { title: "From Curiosity to Code", category: "Essay", url: "/writing/from-curiosity-to-code", desc: "My journey into the world of computers." },
        { title: "Why I Write in Public", category: "Essay", url: "/writing/why-i-write-in-public", desc: "Normalizing failure and building in the open." },
        { title: "Engineering Journal: July 2026", category: "Journal", url: "/writing/engineering-journal-july-2026", desc: "Monthly summary of built projects, technical lessons, book logs, system failures." },
        { title: "Lessons From Building DailyDine", category: "Engineering", url: "/writing/lessons-from-building-dailydine", desc: "Database isolation keys and concurrency logs." },
        { title: "My Cybersecurity Roadmap", category: "Cybersecurity", url: "/writing/my-cybersecurity-roadmap", desc: "Networking layers and memory exploitation curriculum." },
        { title: "Analyzing JWT Authentication Mechanisms", category: "Cybersecurity", url: "/writing/analyzing-jwt-authentication", desc: "XSS prevention and cookie storage scopes." },
        { title: "Learning Linux From Scratch", category: "Field Notes", url: "/writing/learning-linux-from-scratch", desc: "CLI operations and permissions boundaries." },
        { title: "Linux Network Security and Port Monitoring Logs", category: "Field Notes", url: "/writing/linux-network-security", desc: "Iptables configurations and socket audits." },
        
        { title: "DailyDine Reservation Queue", category: "Work", url: "/work/dailydine", desc: "Concurrency coordination platform case study." },
        { title: "HisabProx Client Invoice Utility", category: "Work", url: "/work/hisabprox", desc: "Local-first static invoice builder case study." },
        
        { title: "Linux: Understanding Socket File Descriptors", category: "Note", url: "/notes", desc: "File systems descriptor modeling." },
        { title: "Git: The Directed Acyclic Graph (DAG) Model", category: "Note", url: "/notes", desc: "Git snapshots and object database graph." },
        { title: "Docker: Namespaces and Control Groups (cgroups)", category: "Note", url: "/notes", desc: "Standard processes running in kernel namespaces." },
        { title: "Rust: Ownership and Memory Borrowing Rules", category: "Note", url: "/notes", desc: "Ownership, borrow checkers, and compile-time guarantees." },
        { title: "Networking: The TCP Sliding Window Protocol", category: "Note", url: "/notes", desc: "Congestion control buffers and sliding windows." },
        { title: "Postgres: Multi-Version Concurrency Control (MVCC)", category: "Note", url: "/notes", desc: "Row transaction IDs and non-blocking reads." },
        { title: "AI: Weights Transformations and Attention Maps", category: "Note", url: "/notes", desc: "Self-attention matrix math." },
        { title: "Security: Stack Frames and Buffer Overflows", category: "Note", url: "/notes", desc: "Function return addresses and instruction injection." }
      ];

      function toggleSearch(forceState) {
        isOpen = forceState !== undefined ? forceState : !isOpen;
        if (isOpen) {
          searchModal.classList.remove('opacity-0', 'pointer-events-none');
          searchInput.focus();
          document.body.style.overflow = 'hidden';
          renderResults("");
        } else {
          searchModal.classList.add('opacity-0', 'pointer-events-none');
          searchInput.value = "";
          document.body.style.overflow = '';
        }
      }

      function renderResults(query) {
        searchResults.innerHTML = "";
        activeIndex = -1;
        
        if (!query) {
          filteredItems = searchData.slice(0, 6); // Show top pages by default
        } else {
          const lowerQuery = query.toLowerCase();
          filteredItems = searchData.filter(item => 
            item.title.toLowerCase().includes(lowerQuery) || 
            item.desc.toLowerCase().includes(lowerQuery) ||
            item.category.toLowerCase().includes(lowerQuery)
          );
        }

        if (filteredItems.length === 0) {
          searchResults.innerHTML = `<div class="text-xs text-[#71717A] p-4 text-center">No results found for "${query}"</div>`;
          return;
        }

        filteredItems.forEach((item, index) => {
          const itemEl = document.createElement('a');
          itemEl.href = item.url;
          itemEl.className = "flex flex-col gap-0.5 p-3 rounded-lg hover:bg-white/5 transition-colors duration-100 group/item";
          itemEl.setAttribute('data-index', index);
          itemEl.innerHTML = `
            <div class="flex items-baseline justify-between">
              <span class="text-sm font-medium text-[#FAFAFA] group-hover/item:text-[#2563EB] transition-colors">${item.title}</span>
              <span class="text-[10px] font-mono uppercase tracking-wider text-[#71717A]">${item.category}</span>
            </div>
            <span class="text-xs text-[#A1A1AA] line-clamp-1">${item.desc}</span>
          `;
          searchResults.appendChild(itemEl);
        });
      }

      function updateActiveItem(direction) {
        const items = searchResults.querySelectorAll('a');
        if (items.length === 0) return;

        if (activeIndex >= 0) {
          items[activeIndex].classList.remove('bg-white/5');
        }

        if (direction === 'down') {
          activeIndex = (activeIndex + 1) % items.length;
        } else if (direction === 'up') {
          activeIndex = activeIndex <= 0 ? items.length - 1 : activeIndex - 1;
        }

        const activeEl = items[activeIndex];
        activeEl.classList.add('bg-white/5');
        activeEl.scrollIntoView({ block: 'nearest' });
      }

      // Hotkey listeners
      window.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          toggleSearch();
        }
        if (e.key === '/') {
          if (document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
            e.preventDefault();
            toggleSearch(true);
          }
        }
        if (isOpen) {
          if (e.key === 'Escape') {
            e.preventDefault();
            toggleSearch(false);
          }
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            updateActiveItem('down');
          }
          if (e.key === 'ArrowUp') {
            e.preventDefault();
            updateActiveItem('up');
          }
          if (e.key === 'Enter') {
            e.preventDefault();
            if (activeIndex >= 0 && filteredItems[activeIndex]) {
              window.location.href = filteredItems[activeIndex].url;
            }
          }
        }
      });

      searchInput.addEventListener('input', (e) => {
        renderResults(e.target.value);
      });

      // Mouse close
      searchModal.addEventListener('click', (e) => {
        if (e.target === searchModal) {
          toggleSearch(false);
        }
      });

      closeSearchButton.addEventListener('click', () => {
        toggleSearch(false);
      });

      // Expose globally
      window.toggleSearchModal = toggleSearch;
    </script>

    <!-- Global Styles & Custom Reset -->
    <style is:global>
      /* Base Resets */
      html {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background-color: #09090B;
      }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        font-size: 18px;
      }
      @media (min-width: 1024px) {
        body {
          font-size: 20px;
        }
      }

      /* Heading typography using Geist Sans */
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Geist Sans', 'Inter', system-ui, sans-serif;
        font-weight: 500;
        letter-spacing: -0.02em;
      }

      /* Custom scrollbar matching dark theme */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #09090B;
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 999px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.15);
      }

      /* Firefox scrollbar compatibility */
      * {
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.08) #09090B;
      }

      /* Focus Ring Philosophy (Teach once, visible focus) */
      *:focus-visible {
        outline: 2px solid #2563EB;
        outline-offset: 4px;
      }

      /* Smooth content rendering */
      main {
        opacity: 0;
        animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }

      @keyframes fadeIn {
        to {
          opacity: 1;
        }
      }

      /* Reduced motion support */
      @media (prefers-reduced-motion: reduce) {
        * {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
        main {
          opacity: 1 !important;
          animation: none !important;
        }
      }
    </style>
  </body>
</html>
