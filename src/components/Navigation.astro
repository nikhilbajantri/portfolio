---
const navItems = [
  { name: 'Home', href: '/' },
  { name: 'Writing', href: '/writing', hasRss: true },
  { name: 'Work', href: '/work' },
  { name: 'Reading', href: '/reading' },
  { name: 'About', href: '/about' },
];
---

<header class="w-full border-b border-[rgba(255,255,255,0.08)] bg-[#09090B] sticky top-0 z-40 transition-colors duration-200">
  <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between">
    
    <!-- Logo -->
    <a href="/" class="text-[#FAFAFA] font-display text-lg tracking-tight font-medium hover:text-[#2563EB] transition-colors duration-180">
      nikhilbajantri.dev
    </a>

    <!-- Desktop Navigation & Search -->
    <div class="hidden md:flex items-center gap-8">
      <nav class="flex items-center gap-8">
        {navItems.map((item) => (
          <div class="flex items-center gap-1.5">
            <a
              href={item.href}
              class="text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors duration-180 text-sm font-medium tracking-tight"
            >
              {item.name}
            </a>
            {item.hasRss && (
              <a 
                href="/rss.xml" 
                class="text-[#71717A] hover:text-[#2563EB] transition-colors duration-180" 
                title="RSS Feed"
                aria-label="RSS Feed"
              >
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 11a9 9 0 0 1 9 9" />
                  <path d="M4 4a16 16 0 0 1 16 16" />
                  <circle cx="5" cy="19" r="1" />
                </svg>
              </a>
            )}
          </div>
        ))}
      </nav>

      <button 
        onclick="window.toggleSearchModal()"
        class="flex items-center gap-2 px-3 py-1.5 bg-[#111113] hover:bg-[#18181B] border border-[rgba(255,255,255,0.08)] rounded-lg text-[#71717A] hover:text-[#FAFAFA] transition-all text-xs font-mono"
        title="Search (⌘K)"
      >
        <span>Search</span>
        <kbd class="px-1.5 py-0.5 bg-[#09090B] border border-[rgba(255,255,255,0.08)] rounded text-[10px]">⌘K</kbd>
      </button>
    </div>

    <!-- Mobile Search & Menu Triggers -->
    <div class="flex items-center gap-2 md:hidden">
      <button 
        onclick="window.toggleSearchModal()"
        class="text-[#A1A1AA] hover:text-[#FAFAFA] p-2"
        aria-label="Search"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>

      <button
        id="mobile-menu-button"
        class="text-[#A1A1AA] hover:text-[#FAFAFA] focus:outline-none transition-colors duration-180 p-2"
        aria-label="Toggle Navigation Menu"
        aria-expanded="false"
      >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="menu-icon-path" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Navigation Drawer -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[rgba(255,255,255,0.08)] bg-[#111113]">
    <nav class="flex flex-col px-6 py-4 gap-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors duration-180 text-sm font-medium py-1"
        >
          {item.name}
        </a>
      ))}
      <a
        href="/rss.xml"
        class="text-[#71717A] hover:text-[#2563EB] transition-colors duration-180 text-sm font-medium py-1 flex items-center gap-1.5"
      >
        <span>RSS Feed</span>
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M4 11a9 9 0 0 1 9 9" />
          <path d="M4 4a16 16 0 0 1 16 16" />
          <circle cx="5" cy="19" r="1" />
        </svg>
      </a>
    </nav>
  </div>
</header>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconPath = document.getElementById('menu-icon-path');

  let isMenuOpen = false;

  mobileMenuButton?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    mobileMenuButton.setAttribute('aria-expanded', isMenuOpen ? 'true' : 'false');
    
    if (isMenuOpen) {
      mobileMenu?.classList.remove('hidden');
      menuIconPath?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    } else {
      mobileMenu?.classList.add('hidden');
      menuIconPath?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    }
  });
</script>
