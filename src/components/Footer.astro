---
const links = [
  { name: 'Now', href: '/now' },
  { name: 'Lab', href: '/lab' },
  { name: 'Knowledge', href: '/knowledge' },
  { name: 'History', href: '/history' },
  { name: 'Uses', href: '/uses' },
  { name: 'Principles', href: '/principles' },
  { name: 'Notes', href: '/notes' },
  { name: 'Colophon', href: '/colophon' },
  { name: 'GitHub', href: 'https://github.com/programmer-nick234/' },
  { name: 'LinkedIn', href: 'https://www.linkedin.com/in/nikhil-bajantri-dev' },
  { name: 'RSS', href: '/rss.xml' },
];
---

<footer class="w-full border-t border-[rgba(255,255,255,0.08)] bg-[#09090B] mt-auto">
  <div class="max-w-[1200px] mx-auto px-6 py-12 flex flex-col gap-12 font-sans">
    
    <!-- Top: Currently Status Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div>
        <span class="text-[#71717A] block text-xs font-mono uppercase tracking-wider mb-1">Building</span>
        <span class="text-sm text-[#A1A1AA]">DailyDine</span>
      </div>
      <div>
        <span class="text-[#71717A] block text-xs font-mono uppercase tracking-wider mb-1">Reading</span>
        <span class="text-sm text-[#A1A1AA]">Designing Data-Intensive Applications</span>
      </div>
      <div>
        <span class="text-[#71717A] block text-xs font-mono uppercase tracking-wider mb-1">Writing</span>
        <span class="text-sm text-[#A1A1AA]">Linux Notes</span>
      </div>
      <div>
        <span class="text-[#71717A] block text-xs font-mono uppercase tracking-wider mb-1">Updated</span>
        <span class="text-sm text-[#A1A1AA]">July 2026</span>
      </div>
    </div>

    <!-- Divider -->
    <div class="h-[1px] bg-[rgba(255,255,255,0.08)] w-full"></div>

    <!-- Bottom: Links and Colophon -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6">
      <!-- Links -->
      <div class="flex flex-wrap gap-x-8 gap-y-2">
        {links.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('http') || link.href.startsWith('mailto') ? "_blank" : undefined}
            rel={link.href.startsWith('http') || link.href.startsWith('mailto') ? "noopener noreferrer" : undefined}
            class="text-sm text-[#71717A] hover:text-[#2563EB] transition-colors duration-180 font-medium"
          >
            {link.name}
          </a>
        ))}
      </div>
      
      <!-- Colophon / Copyright -->
      <div class="text-xs text-[#71717A] font-mono flex flex-col gap-1 sm:items-end">
        <span>Built with Astro · Hosted on Vercel · <a href="/rss.xml" class="hover:underline">RSS</a> · <a href="https://github.com/programmer-nick234/portfolio" class="hover:underline">Source Code</a></span>
        <span>Last updated · July 2026</span>
      </div>
    </div>

  </div>
</footer>
