---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { name: 'Now', href: '/now' },
  { name: 'Uses', href: '/uses' },
  { name: 'Resume', href: '/about/resume' },
  { name: 'RSS', href: '/rss.xml' },
];

const socialLinks = [
  { name: 'GitHub', href: 'https://github.com/programmer-nick234/' },
  { name: 'LinkedIn', href: 'https://www.linkedin.com/in/nikhil-bajantri-dev' },
  { name: 'Email', href: 'mailto:nikhilbajantri2604@gmail.com' },
];
---

<footer class="w-full border-t border-[rgba(255,255,255,0.08)] bg-[#09090B] mt-auto">
  <div class="max-w-[1200px] mx-auto px-6 py-12 flex flex-col md:flex-row md:items-start justify-between gap-8">
    
    <!-- Left: Colophon and Copyright -->
    <div class="flex flex-col gap-4 max-w-sm">
      <div class="text-sm text-[#A1A1AA] leading-relaxed">
        This website was designed and built by me. Built with Astro, Tailwind CSS, TypeScript, and deployed on Vercel. Typography uses Geist, Inter, and JetBrains Mono. The source code is available on GitHub.
      </div>
      <div class="text-xs text-[#71717A] tracking-tight">
        Built carefully. Updated continuously. Last updated: July 2026.
      </div>
    </div>

    <!-- Right: Navigation, Socials and Live Metadata -->
    <div class="flex flex-col sm:flex-row gap-12 sm:gap-16">
      
      <!-- Links -->
      <div class="flex flex-col gap-3">
        <h3 class="text-xs text-[#FAFAFA] font-medium tracking-wider uppercase">Menu</h3>
        <nav class="flex flex-col gap-2">
          {footerLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-[#A1A1AA] hover:text-[#2563EB] transition-colors duration-180"
            >
              {link.name}
            </a>
          ))}
        </nav>
      </div>

      <!-- Socials -->
      <div class="flex flex-col gap-3">
        <h3 class="text-xs text-[#FAFAFA] font-medium tracking-wider uppercase">Connect</h3>
        <div class="flex flex-col gap-2">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-[#A1A1AA] hover:text-[#2563EB] transition-colors duration-180"
            >
              {link.name}
            </a>
          ))}
        </div>
      </div>

      <!-- Live Metadata -->
      <div class="flex flex-col gap-3">
        <h3 class="text-xs text-[#FAFAFA] font-medium tracking-wider uppercase">Status</h3>
        <div class="flex flex-col gap-2 text-sm text-[#A1A1AA]">
          <div>
            <span class="text-[#71717A] block text-xs">Updated</span>
            July 2026
          </div>
          <div>
            <span class="text-[#71717A] block text-xs">Reading</span>
            "The Pragmatic Programmer"
          </div>
          <div>
            <span class="text-[#71717A] block text-xs">Building</span>
            DailyDine
          </div>
        </div>
      </div>

    </div>
  </div>
</footer>
