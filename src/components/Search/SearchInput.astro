---
---
<div class="flex items-center px-6 py-4 border-b border-[rgba(255,255,255,0.08)] h-14 relative shrink-0">
  <!-- Lucide Search Icon -->
  <svg 
    class="w-5 h-5 text-[#71717A] mr-3 shrink-0" 
    xmlns="http://www.w3.org/2000/svg" 
    viewBox="0 0 24 24" 
    fill="none" 
    stroke="currentColor" 
    stroke-width="2" 
    stroke-linecap="round" 
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="8"></circle>
    <path d="m21 21-4.3-4.3"></path>
  </svg>
  
  <input
    id="search-input"
    type="text"
    placeholder="Search articles, projects, knowledge..."
    class="bg-transparent text-sm text-[#FAFAFA] placeholder-[#71717A] w-full outline-none pr-10"
    autocomplete="off"
    spellcheck="false"
  />

  <button 
    id="close-search-button" 
    class="absolute right-6 top-1/2 -translate-y-1/2 text-[10px] font-mono text-[#71717A] hover:text-[#FAFAFA] transition-colors border border-[rgba(255,255,255,0.12)] bg-[#18181B] px-1.5 py-0.5 rounded shadow-sm select-none"
    aria-label="Close search"
  >
    ESC
  </button>
</div>
